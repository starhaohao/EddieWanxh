{%- comment -%}
  Resolves the customer-facing product name per FABRIC V2 blueprint §5/§6.

  Priority:
  1. custom.product_content metaobject -> display_name (source of truth)
  2. Auto-derived clean name: native title with material / technology / colour
     tokens stripped, leaving the silhouette (e.g. "Y TransDRY Brief White" -> "Y Brief")
  3. Native Shopify product title (final fallback)

  The token list is intentionally editable — extend it as the catalogue grows.

  Accepts:
  - product: {Object} product (required)

  Usage: {% render 'product-display-name', product: product %}
{%- endcomment -%}
{%- liquid
  assign pc = product.metafields.custom.product_content.value
  assign resolved_name = ''
  if pc != blank and pc.display_name.value != blank
    assign resolved_name = pc.display_name.value | strip_html
  endif

  if resolved_name == blank
    assign derived = product.title | strip_html
    assign strip_tokens = 'Micromodal,TransDRY®,TransDRY,OEKO-TEX,DryFit,CoolMax,Cotton,Spandex,Modal,Natural,Bamboo,Merino,Wool,Nylon,Elastane,Microfiber,White,Black,Charcoal,Grey,Gray,Navy,Blue,Green,Red,Beige,Olive,Khaki,Brown,Pink,Sand,Stone,®' | split: ','
    for token in strip_tokens
      assign derived = derived | remove: token
    endfor
    assign derived = derived | replace: '  ', ' ' | replace: '  ', ' ' | strip
    if derived != blank
      assign resolved_name = derived
    endif
  endif

  if resolved_name == blank
    assign resolved_name = product.title | strip_html
  endif
  echo resolved_name | escape
-%}
