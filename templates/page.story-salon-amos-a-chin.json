    "section_multicolumn_aa04": {
      "type": "section-multicolumn",
      "blocks": {
        "icon_aa04a": {
          "type": "icon",
          "settings": {
            "column_width": 100,
            "icon_name": "icon-info-empty",
            "image": "shopify://shop_images/Social_Media_Icon-7.jpg",
            "icon_size": 35,
            "icon_alignment": "icon--left",
            "icon_color": "",
            "title": "\"Function first. I don't have the energy to fight with what I'm wearing. It should support me, not compete with me.\"",
            "heading_font_size": "heading-mini",
            "text": "<p>Working across editing, modelling, and making —</p><p>how do clothes function for you?</p>",
            "text_font_size": "body-x-small",
            "heading_tag": "automatic"
          }
        },
        "icon_aa04b": {
          "type": "icon",
          "settings": {
            "column_width": 100,
            "icon_name": "icon-info-empty",
            "image": "shopify://shop_images/Social_Media_Icon-7.jpg",
            "icon_size": 35,
            "icon_alignment": "icon--left",
            "icon_color": "",
            "title": "\"By deciding that what I feel matters more than how I look doing it. The feeling is the point.\"",
            "heading_font_size": "heading-mini",
            "text": "<p>The industry rewards polish.</p><p>How do you resist that?</p>",
            "text_font_size": "body-x-small",
            "heading_tag": "automatic"
          }
        },
        "icon_aa04c": {
          "type": "icon",
          "settings": {
            "column_width": 100,
            "icon_name": "icon-info-empty",
            "image": "shopify://shop_images/Social_Media_Icon-7.jpg",
            "icon_size": 35,
            "icon_alignment": "icon--left",
            "icon_color": "",
            "title": "\"Unfiltered. Present. Mine.\"",
            "heading_font_size": "heading-mini",
            "text": "<p>Three words for your honesty?</p>",
            "text_font_size": "body-x-small",
            "heading_tag": "automatic"
          }
        }
      },
