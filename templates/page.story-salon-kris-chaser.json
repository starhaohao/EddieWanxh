    "section_multicolumn_kc04": {
      "type": "section-multicolumn",
      "blocks": {
        "icon_kc04a": {
          "type": "icon",
          "settings": {
            "column_width": 100,
            "icon_name": "icon-info-empty",
            "image": "shopify://shop_images/Social_Media_Icon-7.jpg",
            "icon_size": 35,
            "icon_alignment": "icon--left",
            "icon_color": "",
            "title": "\"With the same care I give the work. I want to feel at ease — to exist without the clothes announcing themselves.\"",
            "heading_font_size": "heading-mini",
            "text": "<p>As someone who draws bodies all day,</p><p>how do you think about what you put on yours?</p>",
            "text_font_size": "body-x-small",
            "heading_tag": "automatic"
          }
        },
        "icon_kc04b": {
          "type": "icon",
          "settings": {
            "column_width": 100,
            "icon_name": "icon-info-empty",
            "image": "shopify://shop_images/Social_Media_Icon-7.jpg",
            "icon_size": 35,
            "icon_alignment": "icon--left",
            "icon_color": "",
            "title": "\"Choosing softness. Choosing comfort. Being willing to be seen as you actually are, not as you think you should be.\"",
            "heading_font_size": "heading-mini",
            "text": "<p>What does making intimacy visible</p><p>mean in everyday life?</p>",
            "text_font_size": "body-x-small",
            "heading_tag": "automatic"
          }
        },
        "icon_kc04c": {
          "type": "icon",
          "settings": {
            "column_width": 100,
            "icon_name": "icon-info-empty",
            "image": "shopify://shop_images/Social_Media_Icon-7.jpg",
            "icon_size": 35,
            "icon_alignment": "icon--left",
            "icon_color": "",
            "title": "\"Tender. Unhurried. Queer.\"",
            "heading_font_size": "heading-mini",
            "text": "<p>Three words for your work?</p>",
            "text_font_size": "body-x-small",
            "heading_tag": "automatic"
          }
        }
