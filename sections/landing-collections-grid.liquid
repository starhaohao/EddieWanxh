{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign columns = section.settings.columns
-%}

<section class="lcg" style="--lcg-cols:{{ columns }};">
  {%- if heading != blank or subheading != blank -%}
    <div class="lcg__header">
      {%- if subheading != blank -%}<p class="lcg__eyebrow">{{ subheading }}</p>{%- endif -%}
      {%- if heading != blank -%}<h2 class="lcg__heading">{{ heading }}</h2>{%- endif -%}
    </div>
  {%- endif -%}

  <div class="lcg__grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign coll = collections[block.settings.collection]
        assign label = block.settings.label | default: coll.title
        assign coll_img = block.settings.image | default: coll.image
      -%}
      <a class="lcg__item" href="{{ block.settings.link | default: coll.url }}" {{ block.shopify_attributes }}>
        <div class="lcg__img-wrap">
          {%- if coll_img != blank -%}
            <img class="lcg__img" src="{{ coll_img | image_url: width: 1200 }}" alt="{{ label | escape }}" loading="lazy">
          {%- else -%}
            <div class="lcg__img lcg__img--placeholder"></div>
          {%- endif -%}
          <div class="lcg__hover-overlay"></div>
        </div>
        <div class="lcg__caption">
          {%- if block.settings.tag != blank -%}
            <span class="lcg__tag">{{ block.settings.tag }}</span>
          {%- endif -%}
          <span class="lcg__name">{{ label }}</span>
          <span class="lcg__arrow">→</span>
        </div>
      </a>
    {%- endfor -%}
  </div>

  {%- if section.settings.cta_text != blank -%}
    <div class="lcg__footer">
      <a class="lcg__cta" href="{{ section.settings.cta_url }}">{{ section.settings.cta_text }}</a>
    </div>
  {%- endif -%}
</section>

<style>
  .lcg {
    background: #faf9f7;
    padding: 80px 48px;
  }
  .lcg__header {
    text-align: center;
    margin-bottom: 48px;
  }
  .lcg__eyebrow {
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #888;
    margin: 0 0 14px;
  }
  .lcg__heading {
    font-size: clamp(28px, 3.5vw, 48px);
    font-weight: 400;
    letter-spacing: -0.03em;
    color: #111;
    margin: 0;
  }
  .lcg__grid {
    display: grid;
    grid-template-columns: repeat(var(--lcg-cols), 1fr);
    gap: 16px;
  }
  .lcg__item {
    display: block;
    text-decoration: none;
    position: relative;
    overflow: hidden;
  }
  .lcg__img-wrap {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }
  .lcg__img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.55s cubic-bezier(0.25,0,0,1);
    display: block;
  }
  .lcg__img--placeholder {
    background: #e8e4de;
  }
  .lcg__hover-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.08);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .lcg__item:hover .lcg__img { transform: scale(1.04); }
  .lcg__item:hover .lcg__hover-overlay { opacity: 1; }
  .lcg__caption {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 4px 0;
  }
  .lcg__tag {
    font-family: monospace;
    font-size: 8px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #888;
    background: #ede9e3;
    padding: 3px 8px;
    flex-shrink: 0;
  }
  .lcg__name {
    font-size: 14px;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: #111;
    flex: 1;
  }
  .lcg__arrow {
    font-size: 14px;
    color: #aaa;
    transition: color 0.2s, transform 0.2s;
  }
  .lcg__item:hover .lcg__arrow { color: #111; transform: translateX(4px); }
  .lcg__footer {
    text-align: center;
    margin-top: 48px;
  }
  .lcg__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 36px;
    border: 1px solid #222;
    font-family: monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: #111;
    background: transparent;
    transition: background 0.2s, color 0.2s;
  }
  .lcg__cta:hover { background: #111; color: #fff; }
  @media (max-width: 989px) {
    .lcg { padding: 60px 24px; }
    .lcg__grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }
  @media (max-width: 749px) {
    .lcg { padding: 48px 16px; }
    .lcg__grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }
</style>

{% schema %}
{
  "name": "Collections Grid",
  "tag": "div",
  "class": "landing-collections-grid-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Category" },
    { "type": "text", "id": "subheading", "label": "Eyebrow label", "default": "Collections" },
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "text", "id": "cta_text", "label": "Footer CTA text", "default": "View All" },
    { "type": "url", "id": "cta_url", "label": "Footer CTA link" }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Override image" },
        { "type": "text", "id": "label", "label": "Override label" },
        { "type": "text", "id": "tag", "label": "Tag badge", "info": "e.g. New, Sale, Best Seller" },
        { "type": "url", "id": "link", "label": "Override link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections Grid",
      "blocks": [
        { "type": "collection_card", "settings": { "label": "Briefs", "tag": "Best Seller" } },
        { "type": "collection_card", "settings": { "label": "Boxer Trunks" } },
        { "type": "collection_card", "settings": { "label": "Tops", "tag": "New" } }
      ]
    }
  ],
  "templates": ["index", "page"]
}
{% endschema %}
