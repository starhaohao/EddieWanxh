{% comment %}
  Collection Filter Bar
  Horizontal pills: Size (with sale badge) | Style | Color swatches | Size Guide
  Below: Sets upsell promo strip
  Add to collection pages via theme editor (above product grid).
  Filtering uses Shopify storefront filter URL params — enable filters in
  Shopify Admin → Navigation → Collection filters first.
{% endcomment %}

<style>
  #cfb-{{ section.id }} {
    padding: 0 var(--outer, 20px) 0;
    margin-bottom: 20px;
  }

  /* ── Filter row ── */
  .cfb__row {
    display: flex;
    align-items: center;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 2px;
    flex-wrap: nowrap;
  }
  .cfb__row::-webkit-scrollbar { display: none; }

  .cfb__group-label {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--COLOR-TEXT-A50, #888);
    white-space: nowrap;
    flex-shrink: 0;
    padding-right: 2px;
  }

  /* ── Size / style pills ── */
  .cfb__pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 7px 13px;
    border: 1px solid var(--COLOR-BORDER, #ddd);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--COLOR-TEXT, #111);
    background: transparent;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    -webkit-tap-highlight-color: transparent;
  }
  .cfb__pill:hover {
    background: var(--COLOR-TEXT, #111);
    color: var(--COLOR-BG, #fff);
    border-color: var(--COLOR-TEXT, #111);
  }
  .cfb__pill.is-active {
    background: var(--COLOR-TEXT, #111);
    color: var(--COLOR-BG, #fff);
    border-color: var(--COLOR-TEXT, #111);
  }

  /* Sale badge */
  .cfb__sale-dot {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 8px;
    height: 8px;
    background: #e5363a;
    border-radius: 50%;
    border: 1.5px solid var(--COLOR-BG, #fff);
  }

  /* ── Color swatches ── */
  .cfb__swatch {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    flex-shrink: 0;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    outline: 2px solid transparent;
    outline-offset: 2px;
    border: 1.5px solid rgba(0,0,0,0.08);
    transition: outline-color 0.15s;
    -webkit-tap-highlight-color: transparent;
  }
  .cfb__swatch:hover,
  .cfb__swatch.is-active {
    outline-color: var(--COLOR-TEXT, #111);
  }

  /* ── Divider ── */
  .cfb__div {
    width: 1px;
    height: 18px;
    background: var(--COLOR-BORDER, #ddd);
    flex-shrink: 0;
    margin: 0 2px;
  }

  /* ── Size guide button ── */
  .cfb__sg-btn {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--COLOR-TEXT-A50, #888);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-decoration: underline;
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: auto;
  }
  .cfb__sg-btn:hover { color: var(--COLOR-TEXT, #111); }

  /* ── Sets promo strip ── */
  .cfb__sets-strip {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 12px;
    padding: 11px 16px;
    background: var(--COLOR-TEXT, #111);
    color: var(--COLOR-BG, #fff);
  }
  .cfb__sets-label {
    font-family: 'Galdeano', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .cfb__sets-msg {
    font-size: 11px;
    letter-spacing: 0.04em;
    opacity: 0.8;
    flex: 1;
    min-width: 0;
  }
  .cfb__sets-link {
    color: inherit;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(255,255,255,0.5);
    transition: border-color 0.15s;
  }
  .cfb__sets-link:hover { border-color: #fff; }

  @media screen and (max-width: 749px) {
    .cfb__sets-msg { display: none; }
    #cfb-{{ section.id }} { padding: 0 var(--outer, 16px); margin-bottom: 16px; }
  }

  /* ── SIZE GUIDE MODAL ── */
  .cfb-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 9998;
    align-items: flex-end;
    justify-content: center;
  }
  .cfb-overlay.is-open { display: flex; }

  @media screen and (min-width: 750px) {
    .cfb-overlay { align-items: center; }
  }

  .cfb-modal {
    background: var(--COLOR-BG, #fff);
    width: 100%;
    max-width: 520px;
    max-height: 90vh;
    overflow-y: auto;
    padding: 28px 24px 36px;
  }

  .cfb-modal__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 22px;
  }
  .cfb-modal__title {
    font-family: 'Galdeano', sans-serif;
    font-size: 17px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0;
    font-weight: 400;
    color: var(--COLOR-TEXT, #111);
  }
  .cfb-modal__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    font-size: 18px;
    line-height: 1;
    color: var(--COLOR-TEXT, #111);
  }

  /* Units toggle */
  .cfb-units {
    display: flex;
    gap: 0;
    margin-bottom: 16px;
  }
  .cfb-units__btn {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid var(--COLOR-BORDER, #ddd);
    background: transparent;
    color: var(--COLOR-TEXT, #111);
    cursor: pointer;
    padding: 6px 14px;
    transition: background 0.15s, color 0.15s;
  }
  .cfb-units__btn:first-child { border-right: none; }
  .cfb-units__btn.is-active {
    background: var(--COLOR-TEXT, #111);
    color: var(--COLOR-BG, #fff);
    border-color: var(--COLOR-TEXT, #111);
  }

  /* Size table */
  .cfb-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    color: var(--COLOR-TEXT, #111);
  }
  .cfb-table th {
    font-family: 'Galdeano', sans-serif;
    font-weight: 400;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 8px 10px;
    text-align: left;
    border-bottom: 1.5px solid var(--COLOR-TEXT, #111);
  }
  .cfb-table td {
    padding: 10px 10px;
    border-bottom: 1px solid var(--COLOR-BORDER, #e8e8e8);
  }
  .cfb-table tr:last-child td { border-bottom: none; }
  .cfb-table .cfb-size-col {
    font-family: 'Galdeano', sans-serif;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 13px;
  }
  /* Sale row highlight */
  .cfb-table tr.is-sale td { background: #fff6f6; }
  .cfb-table tr.is-sale .cfb-size-col {
    color: #c0392b;
  }
  .cfb-table tr.is-sale .cfb-size-col::after {
    content: ' ↓';
    font-size: 10px;
    opacity: 0.7;
  }

  /* Unit columns */
  .cfb-table .col-cm { display: table-cell; }
  .cfb-table .col-in { display: none; }
  .cfb-table.show-inches .col-cm { display: none; }
  .cfb-table.show-inches .col-in { display: table-cell; }

  .cfb-modal__note {
    margin-top: 18px;
    font-size: 11px;
    line-height: 1.65;
    color: var(--COLOR-TEXT-A50, #888);
  }
</style>

<div id="cfb-{{ section.id }}" class="collection-filter-bar">

  <div class="cfb__row">

    {%- comment -%} ── SIZE FILTER ── {%- endcomment -%}
    {%- if section.settings.show_size_filter -%}
      <span class="cfb__group-label">Size</span>

      {%- assign size_list = section.settings.size_options | split: ',' -%}
      {%- assign sale_list = section.settings.sale_sizes | split: ',' -%}

      {%- for s in size_list -%}
        {%- assign sz = s | strip -%}
        {%- assign on_sale = false -%}
        {%- for sl in sale_list -%}
          {%- if sl | strip == sz -%}{%- assign on_sale = true -%}{%- endif -%}
        {%- endfor -%}

        <a
          href="{{ collection.url }}?filter.v.option.size={{ sz | url_encode }}"
          class="cfb__pill"
          data-cfb-filter="size:{{ sz }}"
        >
          {{ sz }}
          {%- if on_sale -%}<span class="cfb__sale-dot" title="On sale"></span>{%- endif -%}
        </a>
      {%- endfor -%}

      <div class="cfb__div"></div>
    {%- endif -%}

    {%- comment -%} ── STYLE FILTER ── {%- endcomment -%}
    {%- if section.settings.show_style_filter -%}
      <span class="cfb__group-label">Style</span>

      {%- assign style_list = section.settings.style_options | split: ',' -%}
      {%- for st in style_list -%}
        {%- assign stl = st | strip -%}
        <a
          href="{{ collection.url }}?filter.p.tag={{ stl | url_encode }}"
          class="cfb__pill"
          data-cfb-filter="style:{{ stl }}"
        >
          {{ stl }}
        </a>
      {%- endfor -%}

      <div class="cfb__div"></div>
    {%- endif -%}

    {%- comment -%} ── COLOR SWATCHES ── {%- endcomment -%}
    {%- if section.settings.show_color_filter -%}
      <span class="cfb__group-label">Color</span>

      {%- assign swatch_lines = section.settings.color_swatches | newline_to_br | split: '<br />' -%}
      {%- for line in swatch_lines -%}
        {%- assign ln = line | strip -%}
        {%- if ln != blank -%}
          {%- assign parts = ln | split: ' : ' -%}
          {%- if parts.size >= 2 -%}
            {%- assign c_name = parts[0] | strip -%}
            {%- assign c_hex  = parts[1] | strip -%}
            <a
              href="{{ collection.url }}?filter.v.option.color={{ c_name | url_encode }}"
              class="cfb__swatch"
              style="background-color: {{ c_hex }};"
              title="{{ c_name }}"
              aria-label="{{ c_name }}"
              data-cfb-filter="color:{{ c_name }}"
            ></a>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      <div class="cfb__div"></div>
    {%- endif -%}

    {%- comment -%} ── SIZE GUIDE TRIGGER ── {%- endcomment -%}
    {%- if section.settings.show_size_guide -%}
      <button
        class="cfb__sg-btn"
        id="cfb-sg-open-{{ section.id }}"
        type="button"
        aria-haspopup="dialog"
      >
        Size Guide
      </button>
    {%- endif -%}

  </div>

  {%- comment -%} ── SETS PROMO STRIP ── {%- endcomment -%}
  {%- if section.settings.show_sets_promo and section.settings.sets_msg != blank -%}
    <div class="cfb__sets-strip">
      {%- if section.settings.sets_label != blank -%}
        <span class="cfb__sets-label">{{ section.settings.sets_label }}</span>
      {%- endif -%}
      <span class="cfb__sets-msg">{{ section.settings.sets_msg }}</span>
      {%- if section.settings.sets_link != blank and section.settings.sets_link_text != blank -%}
        <a class="cfb__sets-link" href="{{ section.settings.sets_link }}">
          {{ section.settings.sets_link_text }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

</div>

{%- comment -%} ── SIZE GUIDE MODAL ── {%- endcomment -%}
{%- if section.settings.show_size_guide -%}
<div
  class="cfb-overlay"
  id="cfb-sg-modal-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  aria-label="Size Guide"
>
  <div class="cfb-modal">
    <div class="cfb-modal__top">
      <h3 class="cfb-modal__title">Size Guide</h3>
      <button class="cfb-modal__close" id="cfb-sg-close-{{ section.id }}" type="button" aria-label="Close">&#215;</button>
    </div>

    <!-- cm / inches toggle -->
    <div class="cfb-units" role="group" aria-label="Units">
      <button class="cfb-units__btn is-active" id="cfb-btn-cm-{{ section.id }}" type="button">CM</button>
      <button class="cfb-units__btn" id="cfb-btn-in-{{ section.id }}" type="button">IN</button>
    </div>

    <table class="cfb-table" id="cfb-table-{{ section.id }}">
      <thead>
        <tr>
          <th>Size</th>
          <th class="col-cm">Waist (cm)</th>
          <th class="col-in">Waist (in)</th>
          <th class="col-cm">Hip (cm)</th>
          <th class="col-in">Hip (in)</th>
        </tr>
      </thead>
      <tbody>
        {%- assign guide_lines = section.settings.size_guide_data | newline_to_br | split: '<br />' -%}
        {%- assign sale_sizes_arr = section.settings.sale_sizes | split: ',' -%}

        {%- for gl in guide_lines -%}
          {%- assign row = gl | strip -%}
          {%- if row != blank -%}
            {%- assign cols = row | split: '|' -%}
            {%- assign row_sz = cols[0] | strip -%}
            {%- assign is_row_sale = false -%}
            {%- for ss in sale_sizes_arr -%}
              {%- if ss | strip == row_sz -%}{%- assign is_row_sale = true -%}{%- endif -%}
            {%- endfor -%}
            <tr{% if is_row_sale %} class="is-sale"{% endif %}>
              <td class="cfb-size-col">{{ row_sz }}</td>
              {%- for c in cols offset: 1 -%}
                {%- assign ci = forloop.index0 | modulo: 2 -%}
                {%- if ci == 0 -%}
                  <td class="col-cm">{{ c | strip }}</td>
                {%- else -%}
                  <td class="col-in">{{ c | strip }}</td>
                {%- endif -%}
              {%- endfor -%}
            </tr>
          {%- endif -%}
        {%- endfor -%}
      </tbody>
    </table>

    {%- if section.settings.size_guide_note != blank -%}
      <p class="cfb-modal__note">{{ section.settings.size_guide_note }}</p>
    {%- endif -%}
  </div>
</div>

<script>
(function() {
  var openBtn   = document.getElementById('cfb-sg-open-{{ section.id }}');
  var modal     = document.getElementById('cfb-sg-modal-{{ section.id }}');
  var closeBtn  = document.getElementById('cfb-sg-close-{{ section.id }}');
  var table     = document.getElementById('cfb-table-{{ section.id }}');
  var btnCm     = document.getElementById('cfb-btn-cm-{{ section.id }}');
  var btnIn     = document.getElementById('cfb-btn-in-{{ section.id }}');
  if (!openBtn || !modal) return;

  function openModal() {
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }
  function closeModal() {
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
    openBtn.focus();
  }

  openBtn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
  });

  /* cm / in toggle */
  if (btnCm && btnIn && table) {
    btnCm.addEventListener('click', function() {
      table.classList.remove('show-inches');
      btnCm.classList.add('is-active');
      btnIn.classList.remove('is-active');
    });
    btnIn.addEventListener('click', function() {
      table.classList.add('show-inches');
      btnIn.classList.add('is-active');
      btnCm.classList.remove('is-active');
    });
  }

  /* Highlight active filters from URL */
  var params = new URLSearchParams(window.location.search);
  document.querySelectorAll('[data-cfb-filter]').forEach(function(el) {
    var kv   = el.dataset.cfbFilter.split(':');
    var type = kv[0], val = kv[1];
    if (type === 'size'  && params.get('filter.v.option.size')  === val) el.classList.add('is-active');
    if (type === 'style' && params.get('filter.p.tag')          === val) el.classList.add('is-active');
    if (type === 'color' && params.get('filter.v.option.color') === val) el.classList.add('is-active');
  });
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Collection Filter Bar",
  "tag": "section",
  "class": "shopify-section--collection-filter-bar",
  "settings": [
    {
      "type": "header",
      "content": "Size Filter"
    },
    {
      "type": "checkbox",
      "id": "show_size_filter",
      "label": "Show size filter",
      "default": true
    },
    {
      "type": "text",
      "id": "size_options",
      "label": "Sizes (comma-separated)",
      "default": "XS, S, M, L, XL, XXL",
      "info": "Must match your product variant option values exactly"
    },
    {
      "type": "text",
      "id": "sale_sizes",
      "label": "Markdown / sale sizes (comma-separated)",
      "placeholder": "XL, XXL",
      "info": "These sizes show a red dot — set lower variant prices in Shopify Admin"
    },
    {
      "type": "header",
      "content": "Style Filter"
    },
    {
      "type": "checkbox",
      "id": "show_style_filter",
      "label": "Show style filter",
      "default": true
    },
    {
      "type": "text",
      "id": "style_options",
      "label": "Styles (comma-separated)",
      "default": "Brief, Trunk, Boxer",
      "info": "Must match product tags in Shopify Admin"
    },
    {
      "type": "header",
      "content": "Color Filter"
    },
    {
      "type": "checkbox",
      "id": "show_color_filter",
      "label": "Show color swatches",
      "default": true
    },
    {
      "type": "textarea",
      "id": "color_swatches",
      "label": "Colors — one per line, format: Name : #hex",
      "default": "Black : #111111\nWhite : #f5f5f5\nNavy : #1a2744\nGrey : #9e9e9e\nRed : #c0392b\nKhaki : #c3b091",
      "info": "e.g. Black : #111111"
    },
    {
      "type": "header",
      "content": "Size Guide"
    },
    {
      "type": "checkbox",
      "id": "show_size_guide",
      "label": "Show size guide button",
      "default": true
    },
    {
      "type": "textarea",
      "id": "size_guide_data",
      "label": "Size guide table — one row per line",
      "info": "Format: SIZE | Waist cm | Waist in | Hip cm | Hip in",
      "default": "XS | 66–71 | 26–28 | 86–91 | 34–36\nS | 71–76 | 28–30 | 91–96 | 36–38\nM | 76–81 | 30–32 | 96–101 | 38–40\nL | 86–91 | 34–36 | 106–111 | 42–44\nXL | 96–101 | 38–40 | 116–121 | 46–48\nXXL | 107–112 | 42–44 | 127–132 | 50–52"
    },
    {
      "type": "text",
      "id": "size_guide_note",
      "label": "Size guide tip",
      "default": "Measure around the narrowest part of your waist and the fullest part of your hips. When between sizes, size up."
    },
    {
      "type": "header",
      "content": "Sets Promo Strip"
    },
    {
      "type": "checkbox",
      "id": "show_sets_promo",
      "label": "Show sets promotion",
      "default": true
    },
    {
      "type": "text",
      "id": "sets_label",
      "label": "Label",
      "default": "Sets Deal"
    },
    {
      "type": "text",
      "id": "sets_msg",
      "label": "Promotion message",
      "default": "Buy any 3 pieces — mix briefs, trunks & boxers — and save 20%"
    },
    {
      "type": "url",
      "id": "sets_link",
      "label": "Shop sets link"
    },
    {
      "type": "text",
      "id": "sets_link_text",
      "label": "Link text",
      "default": "Shop Sets →"
    }
  ],
  "presets": [
    {
      "name": "Collection Filter Bar",
      "settings": {
        "show_size_filter": true,
        "size_options": "XS, S, M, L, XL, XXL",
        "show_style_filter": true,
        "style_options": "Brief, Trunk, Boxer",
        "show_color_filter": true,
        "show_size_guide": true,
        "show_sets_promo": true,
        "sets_label": "Sets Deal",
        "sets_msg": "Buy any 3 pieces — mix briefs, trunks & boxers — and save 20%"
      }
    }
  ]
}
{% endschema %}
