{% comment %}
  Collection Filter Bar — auto-injected on all collection pages via layout/theme.liquid
  Layout:
    [Collection title — scrolls with page]
    [Sticky bar]
      Row 1: Size pills
      Row 2: Style | Color
      Row 3: Size Guide
      Sets promo strip
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">

<style>
  /* ── Collection title (non-sticky) ── */
  .cfb-title {
    padding: 28px var(--outer, 20px) 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(26px, 6vw, 40px);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 400;
    color: var(--COLOR-TEXT, #111);
    margin: 0;
    line-height: 1;
  }

  @media screen and (max-width: 749px) {
    .cfb-title {
      padding: 20px var(--outer, 16px) 12px;
      font-size: clamp(22px, 7vw, 32px);
    }
  }

  /* ── Sticky filter bar ── */
  .cfb {
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--COLOR-BG, #fff);
    border-bottom: 1px solid var(--COLOR-BORDER, #e8e8e8);
  }

  /* Desktop: rows side-by-side via flex */
  .cfb__inner {
    padding: 0 var(--outer, 20px);
    display: flex;
    align-items: stretch;
  }

  /* ── Filter rows ── */
  .cfb__row {
    display: flex;
    align-items: center;
    gap: 0;
    height: 46px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    flex-shrink: 0;
  }
  .cfb__row::-webkit-scrollbar { display: none; }

  /* Row 1 — Size pills */
  .cfb__row--size {
    flex-shrink: 0;
    padding-right: 14px;
    border-right: 1px solid var(--COLOR-BORDER, #e8e8e8);
    margin-right: 14px;
  }

  /* Row 2 — Style + Color (fills remaining width on desktop) */
  .cfb__row--filters {
    flex: 1;
    min-width: 0;
  }

  /* Row 3 — Size Guide (desktop: hidden, always visible on mobile) */
  .cfb__row--guide {
    flex-shrink: 0;
    padding-left: 14px;
    border-left: 1px solid var(--COLOR-BORDER, #e8e8e8);
    margin-left: 14px;
  }

  /* ── Mobile overrides ── */
  @media screen and (max-width: 749px) {
    .cfb__inner {
      flex-direction: column;
      padding: 0;
    }
    .cfb__row {
      height: 44px;
      padding: 0 var(--outer, 16px);
      width: 100%;
      box-sizing: border-box;
      flex-shrink: 0;
    }
    .cfb__row--size {
      border-right: none;
      border-bottom: 1px solid var(--COLOR-BORDER, #e8e8e8);
      padding-right: var(--outer, 16px);
      margin-right: 0;
    }
    .cfb__row--filters {
      border-bottom: 1px solid var(--COLOR-BORDER, #e8e8e8);
    }
    .cfb__row--guide {
      border-left: none;
      border-bottom: 1px solid var(--COLOR-BORDER, #e8e8e8);
      padding-left: var(--outer, 16px);
      margin-left: 0;
      height: 38px;
    }
    /* Size guide button — right-aligned on its own row */
    .cfb__row--guide .cfb__sg-btn {
      font-size: 11px;
    }
  }

  /* ── Group label ── */
  .cfb__group-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--COLOR-TEXT-A50, rgba(17,17,17,0.45));
    white-space: nowrap;
    flex-shrink: 0;
    padding-right: 10px;
  }

  /* ── Pills ── */
  .cfb__pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 30px;
    padding: 0 13px;
    border: 1px solid var(--COLOR-BORDER, #e8e8e8);
    margin-right: 6px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--COLOR-TEXT, #111);
    background: transparent;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    -webkit-tap-highlight-color: transparent;
  }
  .cfb__pill:hover,
  .cfb__pill.is-active {
    background: var(--COLOR-TEXT, #111);
    color: var(--COLOR-BG, #fff);
    border-color: var(--COLOR-TEXT, #111);
  }

  /* Sale red dot */
  .cfb__sale-dot {
    position: absolute;
    top: -3px;
    right: -3px;
    width: 7px;
    height: 7px;
    background: #e5363a;
    border-radius: 50%;
    border: 1.5px solid var(--COLOR-BG, #fff);
  }

  /* ── Color swatches ── */
  .cfb__swatch {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    flex-shrink: 0;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    margin-right: 8px;
    outline: 2px solid transparent;
    outline-offset: 2px;
    border: 1.5px solid rgba(0,0,0,0.1);
    transition: outline-color 0.15s;
    -webkit-tap-highlight-color: transparent;
  }
  .cfb__swatch:hover,
  .cfb__swatch.is-active { outline-color: var(--COLOR-TEXT, #111); }

  /* ── Separator ── */
  .cfb__sep {
    width: 1px;
    height: 16px;
    background: var(--COLOR-BORDER, #e8e8e8);
    flex-shrink: 0;
    margin: 0 14px 0 8px;
  }

  /* ── Size guide button ── */
  .cfb__sg-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #800020;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 3px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: auto;
    transition: color 0.15s;
  }
  .cfb__sg-btn:hover { color: #5a0016; }

  /* ── Sets promo strip ── */
  .cfb__sets {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px var(--outer, 20px);
    background: var(--COLOR-TEXT, #111);
    color: var(--COLOR-BG, #fff);
  }
  .cfb__sets-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .cfb__sets-msg {
    font-size: 11px;
    letter-spacing: 0.03em;
    opacity: 0.75;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cfb__sets-cta {
    font-family: 'DM Sans', sans-serif;
    color: inherit;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(255,255,255,0.4);
    padding-bottom: 1px;
    transition: border-color 0.15s;
  }
  .cfb__sets-cta:hover { border-color: #fff; }

  @media screen and (max-width: 749px) {
    .cfb__sets-msg { display: none; }
    .cfb__sets { padding: 10px var(--outer, 16px); }
  }

  /* ── SIZE GUIDE MODAL ── */
  .cfb-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 9999;
    align-items: flex-end;
    justify-content: center;
  }
  .cfb-overlay.is-open { display: flex; }
  @media screen and (min-width: 750px) {
    .cfb-overlay { align-items: center; }
  }

  .cfb-modal {
    background: var(--COLOR-BG, #fff);
    width: 100%;
    max-width: 500px;
    max-height: 88vh;
    overflow-y: auto;
    padding: 28px 24px 40px;
  }
  .cfb-modal__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .cfb-modal__title {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
    font-weight: 400;
    color: var(--COLOR-TEXT, #111);
  }
  .cfb-modal__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    font-size: 18px;
    line-height: 1;
    color: var(--COLOR-TEXT, #111);
    opacity: 0.5;
    transition: opacity 0.15s;
  }
  .cfb-modal__close:hover { opacity: 1; }

  .cfb-units { display: flex; margin-bottom: 18px; }
  .cfb-unit-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid var(--COLOR-BORDER, #e8e8e8);
    background: transparent;
    color: var(--COLOR-TEXT, #111);
    cursor: pointer;
    padding: 7px 16px;
    transition: background 0.15s, color 0.15s;
  }
  .cfb-unit-btn:first-child { border-right: none; }
  .cfb-unit-btn.is-active {
    background: var(--COLOR-TEXT, #111);
    color: var(--COLOR-BG, #fff);
  }

  .cfb-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    color: var(--COLOR-TEXT, #111);
  }
  .cfb-table th {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 8px 10px;
    text-align: left;
    border-bottom: 1.5px solid var(--COLOR-TEXT, #111);
    color: var(--COLOR-TEXT, #111);
  }
  .cfb-table td {
    padding: 10px 10px;
    border-bottom: 1px solid var(--COLOR-BORDER, #e8e8e8);
    font-size: 12px;
    letter-spacing: 0.02em;
  }
  .cfb-table tr:last-child td { border-bottom: none; }
  .cfb-table .cfb-sz {
    font-family: 'DM Sans', sans-serif;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 13px;
  }
  .cfb-table tr.is-sale td { background: #fff6f6; }
  .cfb-table tr.is-sale .cfb-sz { color: #c0392b; }
  .cfb-table tr.is-sale .cfb-sz::after { content: ' ↓'; font-size: 10px; opacity: 0.6; }

  .cfb-table .col-cm  { display: table-cell; }
  .cfb-table .col-in  { display: none; }
  .cfb-table.show-in .col-cm { display: none; }
  .cfb-table.show-in .col-in { display: table-cell; }

  .cfb-modal__note {
    margin-top: 16px;
    font-size: 11px;
    line-height: 1.7;
    color: var(--COLOR-TEXT-A50, rgba(17,17,17,0.45));
  }
</style>

{%- comment -%} Collection title — scrolls with page, not sticky {%- endcomment -%}
{%- if collection.title != blank -%}
  <p class="cfb-title">{{ collection.title }}</p>
{%- endif -%}

<div class="cfb">
  <div class="cfb__inner">

    {%- comment -%} ROW 1 — Size {%- endcomment -%}
    <div class="cfb__row cfb__row--size">
      {%- if section.settings.show_size_filter -%}
        <span class="cfb__group-label">Size</span>
        {%- assign size_list = section.settings.size_options | split: ',' -%}
        {%- assign sale_list = section.settings.sale_sizes   | split: ',' -%}
        {%- for s in size_list -%}
          {%- assign sz = s | strip -%}
          {%- assign on_sale = false -%}
          {%- for sl in sale_list -%}
            {%- assign sl_stripped = sl | strip -%}
            {%- if sl_stripped == sz -%}{%- assign on_sale = true -%}{%- endif -%}
          {%- endfor -%}
          <a
            href="{{ collection.url }}?filter.v.option.size={{ sz | url_encode }}"
            class="cfb__pill"
            data-cfb="size:{{ sz }}"
          >{{ sz }}{%- if on_sale -%}<span class="cfb__sale-dot" title="On markdown"></span>{%- endif -%}</a>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- comment -%} ROW 2 — Style + Color {%- endcomment -%}
    <div class="cfb__row cfb__row--filters">
      {%- if section.settings.show_style_filter -%}
        <span class="cfb__group-label">Style</span>
        {%- assign style_list = section.settings.style_options | split: ',' -%}
        {%- for st in style_list -%}
          {%- assign stl = st | strip -%}
          <a
            href="{{ collection.url }}?filter.p.tag={{ stl | url_encode }}"
            class="cfb__pill"
            data-cfb="style:{{ stl }}"
          >{{ stl }}</a>
        {%- endfor -%}
        <span class="cfb__sep"></span>
      {%- endif -%}
      {%- if section.settings.show_color_filter -%}
        <span class="cfb__group-label">Color</span>
        {%- assign swatch_rows = section.settings.color_swatches | newline_to_br | split: '<br />' -%}
        {%- for row in swatch_rows -%}
          {%- assign r = row | strip -%}
          {%- if r != blank -%}
            {%- assign pts = r | split: ' : ' -%}
            {%- if pts.size >= 2 -%}
              {%- assign c_name = pts[0] | strip -%}
              {%- assign c_hex  = pts[1] | strip -%}
              <a
                href="{{ collection.url }}?filter.v.option.color={{ c_name | url_encode }}"
                class="cfb__swatch"
                style="background-color:{{ c_hex }};"
                title="{{ c_name }}"
                aria-label="{{ c_name }}"
                data-cfb="color:{{ c_name }}"
              ></a>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- comment -%} ROW 3 — Size Guide {%- endcomment -%}
    {%- if section.settings.show_size_guide -%}
      <div class="cfb__row cfb__row--guide">
        <button class="cfb__sg-btn" id="cfb-open-{{ section.id }}" type="button" aria-haspopup="dialog">
          Size Guide
        </button>
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} SETS PROMO STRIP {%- endcomment -%}
  {%- if section.settings.show_sets_promo and section.settings.sets_msg != blank -%}
    <div class="cfb__sets">
      {%- if section.settings.sets_label != blank -%}
        <span class="cfb__sets-label">{{ section.settings.sets_label }}</span>
      {%- endif -%}
      <span class="cfb__sets-msg">{{ section.settings.sets_msg }}</span>
      {%- if section.settings.sets_link != blank and section.settings.sets_link_text != blank -%}
        <a class="cfb__sets-cta" href="{{ section.settings.sets_link }}">{{ section.settings.sets_link_text }}</a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{%- comment -%} SIZE GUIDE MODAL {%- endcomment -%}
{%- if section.settings.show_size_guide -%}
<div class="cfb-overlay" id="cfb-modal-{{ section.id }}" role="dialog" aria-modal="true" aria-label="Size Guide">
  <div class="cfb-modal">
    <div class="cfb-modal__top">
      <h3 class="cfb-modal__title">Size Guide</h3>
      <button class="cfb-modal__close" id="cfb-close-{{ section.id }}" type="button" aria-label="Close">&#215;</button>
    </div>

    <div class="cfb-units" role="group" aria-label="Units">
      <button class="cfb-unit-btn is-active" id="cfb-cm-{{ section.id }}" type="button">CM</button>
      <button class="cfb-unit-btn"            id="cfb-in-{{ section.id }}" type="button">IN</button>
    </div>

    <table class="cfb-table" id="cfb-tbl-{{ section.id }}">
      <thead>
        <tr>
          <th>Size</th>
          <th class="col-cm">Waist (cm)</th>
          <th class="col-in">Waist (in)</th>
          <th class="col-cm">Hip (cm)</th>
          <th class="col-in">Hip (in)</th>
        </tr>
      </thead>
      <tbody>
        {%- assign guide_rows = section.settings.size_guide_data | newline_to_br | split: '<br />' -%}
        {%- assign sale_arr   = section.settings.sale_sizes | split: ',' -%}
        {%- for gr in guide_rows -%}
          {%- assign row = gr | strip -%}
          {%- if row != blank -%}
            {%- assign cols   = row | split: '|' -%}
            {%- assign row_sz = cols[0] | strip -%}
            {%- assign sale_row = false -%}
            {%- for ss in sale_arr -%}
              {%- assign ss_stripped = ss | strip -%}
              {%- if ss_stripped == row_sz -%}{%- assign sale_row = true -%}{%- endif -%}
            {%- endfor -%}
            <tr{% if sale_row %} class="is-sale"{% endif %}>
              <td class="cfb-sz">{{ row_sz }}</td>
              <td class="col-cm">{{ cols[1] | strip }}</td>
              <td class="col-in">{{ cols[2] | strip }}</td>
              <td class="col-cm">{{ cols[3] | strip }}</td>
              <td class="col-in">{{ cols[4] | strip }}</td>
            </tr>
          {%- endif -%}
        {%- endfor -%}
      </tbody>
    </table>

    {%- if section.settings.size_guide_note != blank -%}
      <p class="cfb-modal__note">{{ section.settings.size_guide_note }}</p>
    {%- endif -%}
  </div>
</div>

<script>
(function() {
  var openBtn  = document.getElementById('cfb-open-{{ section.id }}');
  var modal    = document.getElementById('cfb-modal-{{ section.id }}');
  var closeBtn = document.getElementById('cfb-close-{{ section.id }}');
  var table    = document.getElementById('cfb-tbl-{{ section.id }}');
  var btnCm    = document.getElementById('cfb-cm-{{ section.id }}');
  var btnIn    = document.getElementById('cfb-in-{{ section.id }}');
  if (!openBtn || !modal) return;

  function open()  { modal.classList.add('is-open'); document.body.style.overflow = 'hidden'; closeBtn.focus(); }
  function close() { modal.classList.remove('is-open'); document.body.style.overflow = ''; openBtn.focus(); }

  openBtn.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  modal.addEventListener('click', function(e) { if (e.target === modal) close(); });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) close();
  });

  if (btnCm && btnIn && table) {
    btnCm.addEventListener('click', function() {
      table.classList.remove('show-in');
      btnCm.classList.add('is-active'); btnIn.classList.remove('is-active');
    });
    btnIn.addEventListener('click', function() {
      table.classList.add('show-in');
      btnIn.classList.add('is-active'); btnCm.classList.remove('is-active');
    });
  }

  var params = new URLSearchParams(window.location.search);
  document.querySelectorAll('[data-cfb]').forEach(function(el) {
    var kv = el.dataset.cfb.split(':'), type = kv[0], val = kv[1];
    if (type === 'size'  && params.get('filter.v.option.size')  === val) el.classList.add('is-active');
    if (type === 'style' && params.get('filter.p.tag')          === val) el.classList.add('is-active');
    if (type === 'color' && params.get('filter.v.option.color') === val) el.classList.add('is-active');
  });
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Collection Filter Bar",
  "tag": "section",
  "class": "shopify-section--collection-filter-bar",
  "settings": [
    {
      "type": "header",
      "content": "Size"
    },
    {
      "type": "checkbox",
      "id": "show_size_filter",
      "label": "Show size filter",
      "default": true
    },
    {
      "type": "text",
      "id": "size_options",
      "label": "Sizes (comma-separated)",
      "default": "XS, S, M, L, XL, XXL",
      "info": "Must match your Shopify variant option values"
    },
    {
      "type": "text",
      "id": "sale_sizes",
      "label": "Markdown sizes (comma-separated)",
      "placeholder": "XL, XXL",
      "info": "Shows a red dot — also set lower variant prices in Shopify Admin"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "checkbox",
      "id": "show_style_filter",
      "label": "Show style filter",
      "default": true
    },
    {
      "type": "text",
      "id": "style_options",
      "label": "Styles (comma-separated)",
      "default": "Brief, Trunk, Boxer",
      "info": "Must match product tags in Shopify Admin"
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "checkbox",
      "id": "show_color_filter",
      "label": "Show color swatches",
      "default": true
    },
    {
      "type": "textarea",
      "id": "color_swatches",
      "label": "Colors — one per line: Name : #hex",
      "default": "Black : #111111\nWhite : #f5f5f5\nNavy : #1a2744\nGrey : #9e9e9e\nRed : #c0392b\nKhaki : #c3b091",
      "info": "e.g.  Black : #111111"
    },
    {
      "type": "header",
      "content": "Size Guide"
    },
    {
      "type": "checkbox",
      "id": "show_size_guide",
      "label": "Show size guide",
      "default": true
    },
    {
      "type": "textarea",
      "id": "size_guide_data",
      "label": "Table rows — one per line",
      "info": "Format: SIZE | Waist cm | Waist in | Hip cm | Hip in",
      "default": "XS | 66–71 | 26–28 | 86–91 | 34–36\nS | 71–76 | 28–30 | 91–96 | 36–38\nM | 76–81 | 30–32 | 96–101 | 38–40\nL | 86–91 | 34–36 | 106–111 | 42–44\nXL | 96–101 | 38–40 | 116–121 | 46–48\nXXL | 107–112 | 42–44 | 127–132 | 50–52"
    },
    {
      "type": "text",
      "id": "size_guide_note",
      "label": "Tip text",
      "default": "Measure your natural waist and the fullest part of your hips. When between sizes, size up."
    },
    {
      "type": "header",
      "content": "Sets Promotion"
    },
    {
      "type": "checkbox",
      "id": "show_sets_promo",
      "label": "Show sets promo strip",
      "default": true
    },
    {
      "type": "text",
      "id": "sets_label",
      "label": "Label",
      "default": "Sets Deal"
    },
