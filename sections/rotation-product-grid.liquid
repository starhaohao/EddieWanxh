{%- liquid
  assign col = collections[section.settings.collection]
  assign heading = section.settings.heading
  assign sizing_note = section.settings.sizing_note
-%}

<section class="rpg" id="rpg-{{ section.id }}">
  <div class="rpg__head">
    <h2 class="rpg__title">{{ heading | default: 'The collection' }}</h2>
    {%- if col != blank -%}
      <span class="rpg__count">{{ col.products_count }} {{ col.products_count | pluralize: 'style', 'styles' }} available</span>
    {%- endif -%}
  </div>

  <div class="rpg__grid">
    {%- if col != blank and col.products.size > 0 -%}
      {%- for product in col.products limit: 20 -%}
        {%- assign pnum = forloop.index | prepend: '0' | slice: -2, 2 -%}
        <div class="rpg__card" data-product-id="{{ product.id }}">
          <a class="rpg__img" href="{{ product.url }}">
            {%- if product.featured_image != blank -%}
              <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy">
            {%- else -%}
              <div class="rpg__img-ph"><span>{{ product.title }}</span></div>
            {%- endif -%}
            <span class="rpg__num">{{ pnum }}</span>
          </a>
          <div class="rpg__info">
            <a class="rpg__name" href="{{ product.url }}">{{ product.title }}</a>
            <div class="rpg__price">
              {%- if product.compare_at_price > product.price -%}
                <span class="rpg__now">{{ product.price | money }}</span>
                <span class="rpg__was">{{ product.compare_at_price | money }}</span>
              {%- else -%}
                <span class="rpg__now">{{ product.price | money }}</span>
              {%- endif -%}
            </div>

            {%- comment -%} Size / variant selector {%- endcomment -%}
            {%- assign option_index = nil -%}
            {%- for opt in product.options -%}
              {%- assign opt_down = opt | downcase -%}
              {%- if opt_down == 'size' -%}
                {%- assign option_index = forloop.index0 -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if option_index != nil -%}
              <div class="rpg__sizes" data-rpg-sizes>
                {%- assign seen_sizes = '' -%}
                {%- for variant in product.variants -%}
                  {%- assign sv = variant.options[option_index] -%}
                  {%- unless seen_sizes contains sv -%}
                    {%- assign seen_sizes = seen_sizes | append: sv | append: ',' -%}
                    {%- assign is_avail = false -%}
                    {%- for v2 in product.variants -%}
                      {%- if v2.options[option_index] == sv and v2.available -%}
                        {%- assign is_avail = true -%}
                      {%- endif -%}
                    {%- endfor -%}
                    <button
                      class="rpg__sz{%- unless is_avail %} rpg__sz--oos{%- endunless %}"
                      data-size="{{ sv | escape }}"
                      data-product-id="{{ product.id }}"
                      {%- unless is_avail %} disabled{%- endunless %}
                    >{{ sv }}</button>
                  {%- endunless -%}
                {%- endfor -%}
              </div>
            {%- else -%}
              {%- comment -%} No size option — render single ATC directly {%- endcomment -%}
              <div class="rpg__sizes" data-rpg-sizes></div>
            {%- endif -%}

            <button
              class="rpg__atc"
              data-rpg-atc
              data-product-id="{{ product.id }}"
              data-has-sizes="{{ option_index | default: 'none' }}"
              {%- unless product.available %} disabled{%- endunless %}
            >
              {%- if product.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
            </button>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- comment -%} Placeholder cards when no collection selected {%- endcomment -%}
      {%- for i in (1..4) -%}
        <div class="rpg__card rpg__card--ph">
          <div class="rpg__img"><div class="rpg__img-ph"><span>Product {{ i }}</span></div><span class="rpg__num">0{{ i }}</span></div>
          <div class="rpg__info">
            <span class="rpg__name">Select a collection in settings</span>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- if sizing_note != blank -%}
    <div class="rpg__sizing">
      <p>{{ sizing_note }}</p>
    </div>
  {%- endif -%}
</section>

<style>
  .rpg {
    padding: 0 0 80px;
  }
  .rpg__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 40px;
    border-bottom: 1px solid rgba(23,25,28,.1);
  }
  .rpg__title {
    font-size: 22px;
    font-weight: 400;
    letter-spacing: -0.04em;
    color: #17191C;
  }
  .rpg__count {
    font-family: monospace;
    font-size: 10px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: #9A9D98;
  }
  .rpg__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-left: 1px solid rgba(23,25,28,.1);
  }
  .rpg__card {
    display: flex;
    flex-direction: column;
    border-right: 1px solid rgba(23,25,28,.1);
    border-bottom: 1px solid rgba(23,25,28,.1);
  }
  .rpg__card:hover .rpg__img img { transform: scale(1.04); }

  .rpg__img {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: #ECEAE4;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(23,25,28,.1);
    display: block;
    text-decoration: none;
  }
  .rpg__img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .55s cubic-bezier(.25,0,0,1);
  }
  .rpg__img-ph {
    width: 100%; height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rpg__img-ph span {
    font-family: monospace;
    font-size: 8px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(23,25,28,.25);
    text-align: center;
    padding: 16px;
    white-space: pre-line;
    line-height: 2;
  }
  .rpg__num {
    position: absolute;
    top: 12px; left: 12px;
    font-family: monospace;
    font-size: 9px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(23,25,28,.3);
    background: #FAF8F3;
    padding: 3px 6px;
    border: 1px solid rgba(23,25,28,.1);
  }

  .rpg__info {
    padding: 16px 16px 14px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .rpg__name {
    font-size: 13px;
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin-bottom: 4px;
    color: #17191C;
    text-decoration: none;
  }
  .rpg__name:hover { text-decoration: underline; }
  .rpg__price {
    display: flex;
    align-items: baseline;
    gap: 7px;
    margin-bottom: 10px;
  }
  .rpg__now { font-size: 12px; font-weight: 500; color: #17191C; }
  .rpg__was { font-size: 11px; color: #9A9D98; text-decoration: line-through; }

  .rpg__sizes {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 12px;
    min-height: 26px;
  }
  .rpg__sz {
    font-family: monospace;
    font-size: 8px;
    letter-spacing: .07em;
    text-transform: uppercase;
    padding: 4px 7px;
    border: 1px solid rgba(23,25,28,.15);
    color: #17191C;
    background: transparent;
    cursor: pointer;
    transition: background .12s, border-color .12s;
    line-height: 1;
  }
  .rpg__sz:hover { background: #AAC9E3; border-color: #AAC9E3; }
  .rpg__sz--sel { background: #AAC9E3; border-color: #AAC9E3; }
  .rpg__sz--oos {
    color: #9A9D98;
    border-color: rgba(23,25,28,.07);
    text-decoration: line-through;
    cursor: not-allowed;
    opacity: .45;
  }
  .rpg__sz--oos:hover { background: transparent; border-color: rgba(23,25,28,.07); }

  .rpg__atc {
    width: 100%;
    margin-top: auto;
    background: #17191C;
    color: #FAF8F3;
    border: none;
    padding: 10px 12px;
    font-family: monospace;
    font-size: 9px;
    letter-spacing: .16em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background .2s;
  }
  .rpg__atc:hover:not(:disabled) { background: #4A1628; }
  .rpg__atc:disabled { opacity: .5; cursor: not-allowed; }
  .rpg__atc--adding { opacity: .7; cursor: wait; }

  .rpg__sizing {
    border-top: 1px solid rgba(23,25,28,.1);
    padding: 17px 32px;
    text-align: center;
    margin-top: 0;
  }
  .rpg__sizing p {
    font-family: monospace;
    font-size: 10px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: #9A9D98;
  }

  @media (max-width: 1024px) {
    .rpg__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 749px) {
    .rpg__grid { grid-template-columns: repeat(2, 1fr); }
    .rpg__head { padding: 18px 16px; }
    .rpg__sizing { padding: 14px 16px; }
  }
</style>

<script>
(function () {
  var section = document.getElementById('rpg-{{ section.id }}');
  if (!section) return;

  /* Size selection */
  section.querySelectorAll('[data-rpg-sizes]').forEach(function (wrap) {
    wrap.querySelectorAll('.rpg__sz').forEach(function (btn) {
      btn.addEventListener('click', function () {
        wrap.querySelectorAll('.rpg__sz').forEach(function (b) { b.classList.remove('rpg__sz--sel'); });
        btn.classList.add('rpg__sz--sel');
      });
    });
  });

  /* Add to cart */
  section.querySelectorAll('[data-rpg-atc]').forEach(function (atcBtn) {
    atcBtn.addEventListener('click', async function () {
      var card = atcBtn.closest('.rpg__card');
      var productId = atcBtn.dataset.productId;
      var hasSize = atcBtn.dataset.hasSizes !== 'none';

      var variantId = null;

      if (hasSize) {
        var selSzBtn = card.querySelector('.rpg__sz--sel');
        if (!selSzBtn) {
          /* Highlight sizes to prompt selection */
          var sizesWrap = card.querySelector('[data-rpg-sizes]');
          if (sizesWrap) {
            sizesWrap.style.outline = '1px solid #923531';
            setTimeout(function () { sizesWrap.style.outline = ''; }, 1200);
          }
          return;
        }
        var selSize = selSzBtn.dataset.size;

        /* Find matching variant via storefront */
        try {
          var res = await fetch('/products/' + productId + '.js');
          if (!res.ok) throw new Error('product fetch failed');
          var pdata = await res.json();
          for (var i = 0; i < pdata.variants.length; i++) {
            var v = pdata.variants[i];
            if (v.options.indexOf(selSize) !== -1 && v.available) {
              variantId = v.id;
              break;
            }
          }
        } catch (e) { console.warn('rpg: variant lookup failed', e); return; }

        if (!variantId) {
          selSzBtn.classList.add('rpg__sz--oos');
          selSzBtn.disabled = true;
          return;
        }
      } else {
        /* Single-variant product — fetch first available */
        try {
          var res2 = await fetch('/products/' + productId + '.js');
          if (!res2.ok) throw new Error();
          var pd2 = await res2.json();
          variantId = pd2.variants[0] && pd2.variants[0].id;
        } catch (e) { return; }
      }

      if (!variantId) return;

      atcBtn.classList.add('rpg__atc--adding');
      atcBtn.disabled = true;
      var orig = atcBtn.textContent;
      atcBtn.textContent = 'Adding…';

      try {
        var cartRes = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: variantId, quantity: 1 })
        });
        if (!cartRes.ok) throw new Error('cart add failed');
        atcBtn.textContent = 'Added ✓';
        /* Refresh cart drawer/count if theme supports it */
        document.dispatchEvent(new CustomEvent('cart:refresh'));
        setTimeout(function () {
          atcBtn.textContent = orig;
          atcBtn.disabled = false;
          atcBtn.classList.remove('rpg__atc--adding');
        }, 1800);
      } catch (e) {
        atcBtn.textContent = 'Try again';
        atcBtn.disabled = false;
        atcBtn.classList.remove('rpg__atc--adding');
        setTimeout(function () { atcBtn.textContent = orig; }, 2000);
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Rotation Product Grid",
  "tag": "div",
  "class": "rotation-product-grid-section",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Collection to display" },
    { "type": "text", "id": "heading", "label": "Section heading", "default": "The collection" },
    { "type": "text", "id": "sizing_note", "label": "Sizing note (below grid)", "default": "fits close to body — size up for a relaxed fit" }
  ],
  "presets": [
    { "name": "Rotation Product Grid" }
  ],
  "templates": ["page"]
}
{% endschema %}
