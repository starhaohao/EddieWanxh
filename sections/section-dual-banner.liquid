{% comment %}
  Dual Banner — two side-by-side full-width panels
  Desktop: 50/50 split, full viewport width
  Mobile: stacked, 4:5 (1080×1350) aspect ratio per panel
{% endcomment %}

<style>
  #db-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
  }

  #db-{{ section.id }} .db__panel {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    text-decoration: none;
  }

  #db-{{ section.id }} .db__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #db-{{ section.id }} .db__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  #db-{{ section.id }} .db__panel:hover .db__image img {
    transform: scale(1.04);
  }

  #db-{{ section.id }} .db__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.5) 0%,
      rgba(0,0,0,0.15) 40%,
      transparent 65%
    );
    pointer-events: none;
  }

  #db-{{ section.id }} .db__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0 5% 7%;
  }

  /* Heading — uses theme heading font stack automatically */
  #db-{{ section.id }} .db__heading {
    font-family: 'Galdeano', sans-serif;
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin: 0 0 14px;
    word-break: break-word;
  }

  /* Size scale — mirrors the theme's Small/Medium/Large/XL/Huge */
  #db-{{ section.id }}.db-size--small   .db__heading { font-size: clamp(20px, 2.5vw, 32px); }
  #db-{{ section.id }}.db-size--medium  .db__heading { font-size: clamp(28px, 3.8vw, 52px); }
  #db-{{ section.id }}.db-size--large   .db__heading { font-size: clamp(36px, 5.5vw, 72px); }
  #db-{{ section.id }}.db-size--xlarge  .db__heading { font-size: clamp(48px, 7.5vw, 96px); }
  #db-{{ section.id }}.db-size--huge    .db__heading { font-size: clamp(60px, 10vw, 130px); }

  #db-{{ section.id }} .db__cta {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* Text colour variants */
  #db-{{ section.id }}.db--white .db__heading,
  #db-{{ section.id }}.db--white .db__cta { color: #ffffff; }

  #db-{{ section.id }}.db--black .db__heading,
  #db-{{ section.id }}.db--black .db__cta { color: #000000; }

  #db-{{ section.id }}.db--theme .db__heading,
  #db-{{ section.id }}.db--theme .db__cta { color: var(--COLOR-TEXT, #111); }

  #db-{{ section.id }} .db__panel:first-child {
    border-right: 1px solid rgba(255,255,255,0.15);
  }

  /* Mobile — stack, 4:5 ratio */
  @media screen and (max-width: 749px) {
    #db-{{ section.id }} {
      grid-template-columns: 1fr;
    }
    #db-{{ section.id }} .db__panel {
      aspect-ratio: 4 / 5;
      border-right: none !important;
    }
    #db-{{ section.id }} .db__content {
      padding: 0 6% 8%;
    }
    /* Scale up one step on mobile for visual impact */
    #db-{{ section.id }}.db-size--small   .db__heading { font-size: clamp(24px, 7vw, 40px); }
    #db-{{ section.id }}.db-size--medium  .db__heading { font-size: clamp(32px, 9vw, 54px); }
    #db-{{ section.id }}.db-size--large   .db__heading { font-size: clamp(40px, 11vw, 68px); }
    #db-{{ section.id }}.db-size--xlarge  .db__heading { font-size: clamp(52px, 13vw, 84px); }
    #db-{{ section.id }}.db-size--huge    .db__heading { font-size: clamp(64px, 16vw, 110px); }
  }
</style>

<div
  id="db-{{ section.id }}"
  class="dual-banner db--{{ section.settings.text_color }} db-size--{{ section.settings.heading_size }}"
>

  {%- for i in (1..2) -%}
    {%- liquid
      if i == 1
        assign img     = section.settings.image_1
        assign heading = section.settings.heading_1
        assign link    = section.settings.link_1
        assign cta     = section.settings.cta_1
      else
        assign img     = section.settings.image_2
        assign heading = section.settings.heading_2
        assign link    = section.settings.link_2
        assign cta     = section.settings.cta_2
      endif
    -%}

    <a
      class="db__panel"
      href="{{ link | default: '#' }}"
      {% if link == blank %}aria-disabled="true"{% endif %}
    >
      <div class="db__image">
        {%- if img != blank -%}
          {{ img | image_url: width: 1400 | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '(max-width: 749px) 100vw, 50vw',
            alt: heading
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag }}
        {%- endif -%}
      </div>

      {%- if section.settings.show_overlay -%}
        <div class="db__overlay"></div>
      {%- endif -%}

      {%- if heading != blank or cta != blank -%}
        <div class="db__content">
          {%- if heading != blank -%}
            <p class="db__heading">{{ heading }}</p>
          {%- endif -%}
          {%- if cta != blank -%}
            <span class="db__cta">{{ cta }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </a>

  {%- endfor -%}

</div>

{% schema %}
{
  "name": "Dual Banner",
  "tag": "section",
  "class": "shopify-section--dual-banner",
  "settings": [
    {
      "type": "header",
      "content": "Panel 1 (Left)"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading",
      "default": "Men's Summer Sale"
    },
    {
      "type": "text",
      "id": "cta_1",
      "label": "Link label",
      "default": "Explore Men's Summer Sale"
    },
    {
      "type": "url",
      "id": "link_1",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Panel 2 (Right)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading",
      "default": "Women's Summer Sale"
    },
    {
      "type": "text",
      "id": "cta_2",
      "label": "Link label",
      "default": "Explore Women's Summer Sale"
    },
    {
      "type": "url",
      "id": "link_2",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small",  "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large",  "label": "Large" },
        { "value": "xlarge", "label": "Extra large" },
        { "value": "huge",   "label": "Huge" }
      ],
      "default": "xlarge"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text colour",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "black", "label": "Black" },
        { "value": "theme", "label": "Theme colour" }
      ],
      "default": "white"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show gradient overlay (improves text legibility)",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Dual Banner",
      "settings": {
        "heading_1": "Men's Summer Sale",
        "cta_1": "Explore Men's Summer Sale",
        "heading_2": "Women's Summer Sale",
        "cta_2": "Explore Women's Summer Sale",
        "heading_size": "xlarge"
      }
    }
  ]
}
{% endschema %}
