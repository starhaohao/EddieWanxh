{% comment %}
  Dual Banner — two side-by-side full-width panels
  Height system mirrors Broadcast's Image Banner (desktop + mobile selects)
{% endcomment %}

<style>
  #db-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
  }

  #db-{{ section.id }} .db__panel {
    position: relative;
    display: block;
    overflow: hidden;
    text-decoration: none;
  }

  /* ── Desktop heights ── */
  #db-{{ section.id }} .db__panel.image-height              { aspect-ratio: 3 / 4; }
  #db-{{ section.id }} .db__panel.screen-height-full        { height: 100vh; }
  #db-{{ section.id }} .db__panel.screen-height-three-quarters { height: 75vh; }
  #db-{{ section.id }} .db__panel.screen-height-two-thirds  { height: 66.666vh; }
  #db-{{ section.id }} .db__panel.sixty-fifty-height-hero   { height: min(60vw, 800px); }
  #db-{{ section.id }} .db__panel.screen-height-one-half    { height: 50vh; }
  #db-{{ section.id }} .db__panel.screen-height-one-third   { height: 33.333vh; }

  #db-{{ section.id }} .db__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #db-{{ section.id }} .db__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  #db-{{ section.id }} .db__panel:hover .db__image img {
    transform: scale(1.04);
  }

  #db-{{ section.id }} .db__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.5) 0%,
      rgba(0,0,0,0.15) 40%,
      transparent 65%
    );
    pointer-events: none;
  }

  #db-{{ section.id }} .db__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0 5% 7%;
  }

  #db-{{ section.id }} .db__heading {
    font-family: 'Galdeano', sans-serif;
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0 0 12px;
    word-break: break-word;
  }

  /* Size scale — matches Broadcast's Small → Huge */
  #db-{{ section.id }}.db-size--small   .db__heading { font-size: clamp(18px, 2.2vw, 28px); }
  #db-{{ section.id }}.db-size--medium  .db__heading { font-size: clamp(24px, 3.2vw, 42px); }
  #db-{{ section.id }}.db-size--large   .db__heading { font-size: clamp(32px, 4.8vw, 62px); }
  #db-{{ section.id }}.db-size--xlarge  .db__heading { font-size: clamp(42px, 6.5vw, 82px); }
  #db-{{ section.id }}.db-size--huge    .db__heading { font-size: clamp(54px, 9vw, 118px); }

  /* CTA — matches Broadcast's outline button style */
  #db-{{ section.id }} .db__cta {
    display: inline-block;
    padding: 10px 20px;
    border: 1px solid currentColor;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  /* Text colour variants */
  #db-{{ section.id }}.db--white .db__heading,
  #db-{{ section.id }}.db--white .db__cta { color: #ffffff; }
  #db-{{ section.id }}.db--white .db__cta:hover { background: #ffffff; color: #000000; }

  #db-{{ section.id }}.db--black .db__heading,
  #db-{{ section.id }}.db--black .db__cta { color: #000000; }
  #db-{{ section.id }}.db--black .db__cta:hover { background: #000000; color: #ffffff; }

  #db-{{ section.id }}.db--theme .db__heading,
  #db-{{ section.id }}.db--theme .db__cta { color: var(--COLOR-TEXT, #111); }

  #db-{{ section.id }} .db__panel:first-child {
    border-right: 1px solid rgba(255,255,255,0.15);
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    #db-{{ section.id }} {
      grid-template-columns: 1fr;
    }
    #db-{{ section.id }} .db__panel {
      border-right: none !important;
    }
    #db-{{ section.id }} .db__content {
      padding: 0 6% 8%;
    }

    /* Mobile height overrides */
    #db-{{ section.id }} .db__panel.image-height--mobile                { aspect-ratio: 4 / 5; height: auto; }
    #db-{{ section.id }} .db__panel.screen-height-full--mobile          { height: 100vh; }
    #db-{{ section.id }} .db__panel.screen-height-three-quarters--mobile { height: 75vh; }
    #db-{{ section.id }} .db__panel.screen-height-two-thirds--mobile    { height: 66.666vh; }
    #db-{{ section.id }} .db__panel.sixty-fifty-height-hero--mobile     { height: 75vw; }
    #db-{{ section.id }} .db__panel.screen-height-one-half--mobile      { height: 50vh; }
    #db-{{ section.id }} .db__panel.screen-height-one-third--mobile     { height: 33.333vh; }

    /* Scale up one step on mobile */
    #db-{{ section.id }}.db-size--small   .db__heading { font-size: clamp(22px, 7vw, 36px); }
    #db-{{ section.id }}.db-size--medium  .db__heading { font-size: clamp(28px, 9vw, 48px); }
    #db-{{ section.id }}.db-size--large   .db__heading { font-size: clamp(36px, 11vw, 60px); }
    #db-{{ section.id }}.db-size--xlarge  .db__heading { font-size: clamp(46px, 13vw, 76px); }
    #db-{{ section.id }}.db-size--huge    .db__heading { font-size: clamp(58px, 16vw, 100px); }
  }
</style>

<div
  id="db-{{ section.id }}"
  class="dual-banner db--{{ section.settings.text_color }} db-size--{{ section.settings.heading_size }}"
>

  {%- for i in (1..2) -%}
    {%- liquid
      if i == 1
        assign img     = section.settings.image_1
        assign heading = section.settings.heading_1
        assign link    = section.settings.link_1
        assign cta     = section.settings.cta_1
      else
        assign img     = section.settings.image_2
        assign heading = section.settings.heading_2
        assign link    = section.settings.link_2
        assign cta     = section.settings.cta_2
      endif
    -%}

    <a
      class="db__panel {{ section.settings.height }} {{ section.settings.mobile_height }}"
      href="{{ link | default: '#' }}"
      {% if link == blank %}aria-disabled="true"{% endif %}
    >
      <div class="db__image">
        {%- if img != blank -%}
          {{ img | image_url: width: 1400 | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '(max-width: 749px) 100vw, 50vw',
            alt: heading
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag }}
        {%- endif -%}
      </div>

      {%- if section.settings.show_overlay -%}
        <div class="db__overlay"></div>
      {%- endif -%}

      {%- if heading != blank or cta != blank -%}
        <div class="db__content">
          {%- if heading != blank -%}
            <p class="db__heading">{{ heading }}</p>
          {%- endif -%}
          {%- if cta != blank -%}
            <span class="db__cta">{{ cta }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </a>

  {%- endfor -%}

</div>

{% schema %}
{
  "name": "Dual Banner",
  "tag": "section",
  "class": "shopify-section--dual-banner",
  "settings": [
    {
      "type": "header",
      "content": "Panel 1 (Left)"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading",
      "default": "Men's Summer Sale"
    },
    {
      "type": "text",
      "id": "cta_1",
      "label": "Button label",
      "default": "Explore"
    },
    {
      "type": "url",
      "id": "link_1",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Panel 2 (Right)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading",
      "default": "Women's Summer Sale"
    },
    {
      "type": "text",
      "id": "cta_2",
      "label": "Button label",
      "default": "Explore"
    },
    {
      "type": "url",
      "id": "link_2",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Desktop height",
      "options": [
        { "value": "image-height",                   "label": "Image height" },
        { "value": "screen-height-full",             "label": "Full screen" },
        { "value": "screen-height-three-quarters",   "label": "3/4 of screen" },
        { "value": "screen-height-two-thirds",       "label": "2/3 of screen" },
        { "value": "sixty-fifty-height-hero",        "label": "60 / 50" },
        { "value": "screen-height-one-half",         "label": "1/2 of screen" },
        { "value": "screen-height-one-third",        "label": "1/3 of screen" }
      ],
      "default": "sixty-fifty-height-hero"
    },
    {
      "type": "select",
      "id": "mobile_height",
      "label": "Mobile height",
      "options": [
        { "value": "image-height--mobile",                    "label": "Image height" },
        { "value": "screen-height-full--mobile",              "label": "Full screen" },
        { "value": "screen-height-three-quarters--mobile",    "label": "3/4 of screen" },
        { "value": "screen-height-two-thirds--mobile",        "label": "2/3 of screen" },
        { "value": "sixty-fifty-height-hero--mobile",         "label": "60 / 50" },
        { "value": "screen-height-one-half--mobile",          "label": "1/2 of screen" },
        { "value": "screen-height-one-third--mobile",         "label": "1/3 of screen" }
      ],
      "default": "screen-height-three-quarters--mobile"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small",  "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large",  "label": "Large" },
        { "value": "xlarge", "label": "Extra large" },
        { "value": "huge",   "label": "Huge" }
      ],
      "default": "xlarge"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text colour",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "black", "label": "Black" },
        { "value": "theme", "label": "Theme colour" }
      ],
      "default": "white"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show gradient overlay",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Dual Banner",
      "settings": {
        "heading_1": "Men's Summer Sale",
        "cta_1": "Explore",
        "heading_2": "Women's Summer Sale",
        "cta_2": "Explore",
        "heading_size": "xlarge",
        "height": "sixty-fifty-height-hero",
        "mobile_height": "screen-height-three-quarters--mobile"
      }
    }
  ]
}
{% endschema %}
