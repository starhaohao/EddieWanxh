{%- liquid
  assign product = product
  assign current_variant = product.selected_or_first_available_variant
  assign show_size_guide = section.settings.show_size_guide
  assign show_tabs = section.settings.show_tabs
-%}

<section class="pe" id="pe-{{ section.id }}">

  <div class="pe__layout">

    <!-- Gallery -->
    <div class="pe__gallery">
      <div class="pe__main-img-wrap" id="pe-main-img">
        {%- if product.featured_image -%}
          <img class="pe__main-img" id="pe-featured-img"
            src="{{ product.featured_image | image_url: width: 1400 }}"
            alt="{{ product.featured_image.alt | escape }}"
            loading="eager">
        {%- endif -%}
      </div>
      {%- if product.images.size > 1 -%}
        <div class="pe__thumbs">
          {%- for img in product.images limit: 8 -%}
            <button class="pe__thumb{% if forloop.first %} pe__thumb--active{% endif %}"
              data-src="{{ img | image_url: width: 1400 }}"
              onclick="peSetImage(this)">
              <img src="{{ img | image_url: width: 200 }}" alt="{{ img.alt | escape }}" loading="lazy">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Info -->
    <div class="pe__info">
      <p class="pe__vendor">{{ product.vendor }}</p>
      <h1 class="pe__title">{{ product.title }}</h1>

      <div class="pe__price" id="pe-price">
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="pe__price--compare">{{ current_variant.compare_at_price | money }}</span>
        {%- endif -%}
        <span class="pe__price--current">{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="pe__badge">Sale</span>
        {%- endif -%}
      </div>

      <form id="pe-form-{{ section.id }}" action="/cart/add" method="post" enctype="multipart/form-data">
        <input type="hidden" name="form_type" value="product">
        <input type="hidden" name="utf8" value="✓">

        {%- for option in product.options_with_values -%}
          <div class="pe__option">
            <div class="pe__option-header">
              <label class="pe__option-label">{{ option.name }}</label>
              {%- if show_size_guide and option.name == 'Size' -%}
                <button type="button" class="pe__size-guide-btn" onclick="peOpenSizeGuide()">Size Guide</button>
              {%- endif -%}
            </div>
            <div class="pe__swatches" data-option-index="{{ forloop.index0 }}">
              {%- for value in option.values -%}
                {%- liquid
                  assign variant_available = false
                  for variant in product.variants
                    if variant.options contains value
                      if variant.available
                        assign variant_available = true
                      endif
                    endif
                  endfor
                -%}
                <button type="button"
                  class="pe__swatch{% unless variant_available %} pe__swatch--oos{% endunless %}{% if option.selected_value == value %} pe__swatch--active{% endif %}"
                  data-option-index="{{ forloop.parentloop.index0 }}"
                  data-value="{{ value | escape }}"
                  {% unless variant_available %}disabled{% endunless %}>
                  {{ value }}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}

        <input type="hidden" name="id" id="pe-variant-id-{{ section.id }}" value="{{ current_variant.id }}">

        <div class="pe__actions">
          <button type="submit" class="pe__atc" id="pe-atc-{{ section.id }}"
            {% unless current_variant.available %}disabled{% endunless %}>
            {%- if current_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
          </button>
        </div>
      </form>

      {%- if show_tabs -%}
        <div class="pe__tabs">
          <div class="pe__tab-nav">
            {%- for block in section.blocks -%}
              {%- if block.type == 'tab' -%}
                <button class="pe__tab-btn{% if forloop.first %} pe__tab-btn--active{% endif %}"
                  data-tab="{{ forloop.index0 }}"
                  onclick="peSetTab({{ forloop.index0 }})">
                  {{ block.settings.title }}
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <div class="pe__tab-panels">
            {%- for block in section.blocks -%}
              {%- if block.type == 'tab' -%}
                <div class="pe__tab-panel{% if forloop.first %} pe__tab-panel--active{% endif %}"
                  data-tab="{{ forloop.index0 }}"
                  {{ block.shopify_attributes }}>
                  {{ block.settings.content }}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- else -%}
        <div class="pe__desc">{{ product.description }}</div>
      {%- endif -%}
    </div>
  </div>

</section>

<!-- Sticky Add-to-Cart Bar -->
<div class="pe__sticky-bar" id="pe-sticky-{{ section.id }}">
  <div class="pe__sticky-inner">
    <div class="pe__sticky-info">
      {%- if product.featured_image -%}
        <img class="pe__sticky-img" src="{{ product.featured_image | image_url: width: 120 }}" alt="{{ product.title | escape }}">
      {%- endif -%}
      <div>
        <p class="pe__sticky-title">{{ product.title }}</p>
        <p class="pe__sticky-price" id="pe-sticky-price-{{ section.id }}">{{ current_variant.price | money }}</p>
      </div>
    </div>
    <button class="pe__sticky-atc" id="pe-sticky-atc-{{ section.id }}"
      {% unless current_variant.available %}disabled{% endunless %}>
      {%- if current_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
    </button>
  </div>
</div>

{%- if show_size_guide -%}
<!-- Size Guide Modal -->
<div class="pe__size-modal" id="pe-size-modal" aria-modal="true" role="dialog" hidden>
  <div class="pe__size-modal-backdrop" onclick="peCloseSizeGuide()"></div>
  <div class="pe__size-modal-inner">
    <button class="pe__size-modal-close" onclick="peCloseSizeGuide()" aria-label="Close">✕</button>
    <h2 class="pe__size-modal-title">Size Guide</h2>
    {%- for block in section.blocks -%}
      {%- if block.type == 'size_guide' -%}
        <div class="pe__size-modal-content" {{ block.shopify_attributes }}>{{ block.settings.content }}</div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

<div class="pe__toast" id="pe-toast-{{ section.id }}" aria-live="polite"></div>

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var product = {{ product | json }};
  var variants = product.variants;

  var selectedOptions = {};
  {%- for option in product.options_with_values -%}
  selectedOptions[{{ forloop.index0 }}] = {{ option.selected_value | json }};
  {%- endfor -%}

  function findVariant() {
    var opts = Object.values(selectedOptions);
    return variants.find(function(v) {
      return opts.every(function(o, i) { return v['option' + (i+1)] === o; });
    });
  }

  function updateVariant() {
    var variant = findVariant();
    if (!variant) return;

    document.getElementById('pe-variant-id-' + sectionId).value = variant.id;

    var priceEl = document.getElementById('pe-price');
    if (priceEl) {
      var fmtPrice = formatMoney(variant.price);
      var fmtCompare = variant.compare_at_price > variant.price ? formatMoney(variant.compare_at_price) : '';
      priceEl.innerHTML =
        (fmtCompare ? '<span class="pe__price--compare">' + fmtCompare + '</span>' : '') +
        '<span class="pe__price--current">' + fmtPrice + '</span>' +
        (fmtCompare ? '<span class="pe__badge">Sale</span>' : '');
    }

    var atc = document.getElementById('pe-atc-' + sectionId);
    var satc = document.getElementById('pe-sticky-atc-' + sectionId);
    var sPrice = document.getElementById('pe-sticky-price-' + sectionId);
    var label = variant.available ? 'Add to Cart' : 'Sold Out';
    if (atc) { atc.textContent = label; atc.disabled = !variant.available; }
    if (satc) { satc.textContent = label; satc.disabled = !variant.available; }
    if (sPrice) sPrice.textContent = formatMoney(variant.price);

    if (variant.featured_image) {
      var img = document.getElementById('pe-featured-img');
      if (img) img.src = variant.featured_image.src.replace(/(\.[a-z]+)$/, '_1400x$1');
    }

    history.replaceState({}, '', '?variant=' + variant.id);
  }

  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2).replace(/\.00$/, '');
  }

  document.addEventListener('click', function(e) {
    var swatch = e.target.closest('.pe__swatch:not([disabled])');
    if (!swatch) return;
    var idx = parseInt(swatch.dataset.optionIndex);
    selectedOptions[idx] = swatch.dataset.value;

    var group = swatch.closest('.pe__swatches');
    group.querySelectorAll('.pe__swatch').forEach(function(s) {
      s.classList.toggle('pe__swatch--active', s.dataset.value === swatch.dataset.value);
    });

    updateVariant();
  });

  function submitCart(btn) {
    var variantId = document.getElementById('pe-variant-id-' + sectionId).value;
    if (!variantId) return;
    var origText = btn.textContent;
    btn.disabled = true;
    btn.textContent = '...';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      btn.textContent = '✓ Added';
      var toast = document.getElementById('pe-toast-' + sectionId);
      if (toast) { toast.textContent = (data.title || product.title) + ' added to cart'; toast.classList.add('pe__toast--show'); setTimeout(function() { toast.classList.remove('pe__toast--show'); }, 2500); }
      document.dispatchEvent(new CustomEvent('cart:refresh'));
      setTimeout(function() { btn.textContent = origText; btn.disabled = false; }, 2000);
    })
    .catch(function() { btn.textContent = origText; btn.disabled = false; });
  }

  var form = document.getElementById('pe-form-' + sectionId);
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      submitCart(document.getElementById('pe-atc-' + sectionId));
    });
  }

  var satcBtn = document.getElementById('pe-sticky-atc-' + sectionId);
  if (satcBtn) satcBtn.addEventListener('click', function() { submitCart(this); });

  var stickyBar = document.getElementById('pe-sticky-' + sectionId);
  var productSection = document.getElementById('pe-' + sectionId);
  if (stickyBar && productSection) {
    var observer = new IntersectionObserver(function(entries) {
      stickyBar.classList.toggle('pe__sticky-bar--visible', !entries[0].isIntersecting);
    }, { threshold: 0 });
    observer.observe(productSection);
  }
})();

function peSetImage(btn) {
  var mainImg = document.getElementById('pe-featured-img');
  if (mainImg && btn.dataset.src) mainImg.src = btn.dataset.src;
  btn.closest('.pe__gallery').querySelectorAll('.pe__thumb').forEach(function(t) {
    t.classList.toggle('pe__thumb--active', t === btn);
  });
}

function peSetTab(idx) {
  document.querySelectorAll('.pe__tab-btn').forEach(function(b, i) {
    b.classList.toggle('pe__tab-btn--active', i === idx);
  });
  document.querySelectorAll('.pe__tab-panel').forEach(function(p, i) {
    p.classList.toggle('pe__tab-panel--active', i === idx);
  });
}

function peOpenSizeGuide() {
  var modal = document.getElementById('pe-size-modal');
  if (modal) { modal.hidden = false; document.body.style.overflow = 'hidden'; }
}
function peCloseSizeGuide() {
  var modal = document.getElementById('pe-size-modal');
  if (modal) { modal.hidden = true; document.body.style.overflow = ''; }
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') peCloseSizeGuide();
});
</script>

<style>
  .pe {
    background: #faf9f7;
    padding: 48px 48px 80px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .pe__layout {
    display: grid;
    grid-template-columns: 1fr 480px;
    gap: 64px;
    align-items: start;
  }
  .pe__gallery { position: sticky; top: 24px; }
  .pe__main-img-wrap {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #f0ede8;
    margin-bottom: 12px;
  }
  .pe__main-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: opacity 0.2s; }
  .pe__thumbs { display: flex; gap: 8px; flex-wrap: wrap; }
  .pe__thumb {
    width: 72px; height: 72px;
    border: 2px solid transparent;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    background: #f0ede8;
    transition: border-color 0.2s;
  }
  .pe__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pe__thumb--active { border-color: #111; }
  .pe__vendor {
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #888;
    margin: 0 0 10px;
  }
  .pe__title {
    font-size: clamp(24px, 2.8vw, 36px);
    font-weight: 400;
    letter-spacing: -0.03em;
    color: #111;
    margin: 0 0 20px;
    line-height: 1.1;
  }
  .pe__price {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 28px;
  }
  .pe__price--compare {
    font-size: 14px;
    text-decoration: line-through;
    color: #aaa;
    font-family: monospace;
  }
  .pe__price--current {
    font-size: 20px;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: #111;
  }
  .pe__badge {
    font-family: monospace;
    font-size: 8px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    background: #922;
    color: #fff;
    padding: 3px 8px;
  }
  .pe__option { margin-bottom: 20px; }
  .pe__option-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  .pe__option-label {
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #555;
  }
  .pe__size-guide-btn {
    font-family: monospace;
    font-size: 8px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #888;
    background: none;
    border: none;
    border-bottom: 1px solid #bbb;
    padding: 0 0 2px;
    cursor: pointer;
    transition: color 0.2s;
  }
  .pe__size-guide-btn:hover { color: #111; border-color: #111; }
  .pe__swatches { display: flex; gap: 6px; flex-wrap: wrap; }
  .pe__swatch {
    min-width: 44px;
    padding: 9px 12px;
    font-family: monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    border: 1px solid #ddd;
    background: #fff;
    color: #111;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
    text-align: center;
  }
  .pe__swatch:hover:not([disabled]) { border-color: #111; }
  .pe__swatch--active { background: #111; color: #fff; border-color: #111; }
  .pe__swatch--oos {
    opacity: 0.3;
    text-decoration: line-through;
    cursor: not-allowed;
  }
  .pe__actions { margin: 28px 0; }
  .pe__atc {
    width: 100%;
    padding: 18px;
    font-family: monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    background: #111;
    color: #fff;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }
  .pe__atc:hover:not([disabled]) { background: #333; }
  .pe__atc[disabled] { background: #ccc; cursor: not-allowed; }

  /* Tabs */
  .pe__tabs { margin-top: 32px; border-top: 1px solid #e8e4de; }
  .pe__tab-nav { display: flex; border-bottom: 1px solid #e8e4de; }
  .pe__tab-btn {
    padding: 14px 20px;
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: #888;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    margin-bottom: -1px;
  }
  .pe__tab-btn--active { color: #111; border-bottom-color: #111; }
  .pe__tab-panel { display: none; padding: 24px 0; font-size: 14px; color: #444; line-height: 1.7; }
  .pe__tab-panel--active { display: block; }
  .pe__desc { margin-top: 32px; font-size: 14px; color: #444; line-height: 1.7; border-top: 1px solid #e8e4de; padding-top: 24px; }

  /* Sticky bar */
  .pe__sticky-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: #fff;
    border-top: 1px solid rgba(0,0,0,0.1);
    padding: 12px 32px;
    z-index: 100;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.25,0,0,1);
    box-shadow: 0 -4px 24px rgba(0,0,0,0.08);
  }
  .pe__sticky-bar--visible { transform: translateY(0); }
  .pe__sticky-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .pe__sticky-info { display: flex; align-items: center; gap: 12px; }
  .pe__sticky-img { width: 48px; height: 48px; object-fit: cover; }
  .pe__sticky-title {
    font-size: 13px;
    font-weight: 400;
    color: #111;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .pe__sticky-price {
    font-family: monospace;
    font-size: 11px;
    color: #555;
    margin: 2px 0 0;
  }
  .pe__sticky-atc {
    padding: 13px 32px;
    font-family: monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: #111;
    color: #fff;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.2s;
  }
  .pe__sticky-atc:hover:not([disabled]) { background: #333; }
  .pe__sticky-atc[disabled] { background: #ccc; cursor: not-allowed; }

  /* Size modal */
  .pe__size-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .pe__size-modal[hidden] { display: none; }
  .pe__size-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
  }
  .pe__size-modal-inner {
    position: relative;
    background: #fff;
    width: 100%;
    max-width: 640px;
    max-height: 80vh;
    overflow-y: auto;
    padding: 40px 48px;
    border-radius: 12px 12px 0 0;
  }
  .pe__size-modal-close {
    position: absolute;
    top: 20px; right: 24px;
    background: none;
    border: none;
    font-size: 16px;
    color: #888;
    cursor: pointer;
  }
  .pe__size-modal-close:hover { color: #111; }
  .pe__size-modal-title {
    font-size: 18px;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: #111;
    margin: 0 0 24px;
  }
  .pe__size-modal-content { font-size: 13px; color: #444; line-height: 1.7; }
  .pe__size-modal-content table { width: 100%; border-collapse: collapse; margin-top: 16px; }
  .pe__size-modal-content th, .pe__size-modal-content td { border: 1px solid #e8e4de; padding: 8px 12px; font-family: monospace; font-size: 10px; text-align: center; }
  .pe__size-modal-content th { background: #f0ede8; text-transform: uppercase; letter-spacing: 0.12em; }

  /* Toast */
  .pe__toast {
    position: fixed;
    bottom: 80px;
    left: 50%;
    transform: translateX(-50%) translateY(16px);
    background: #111;
    color: #fff;
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 12px 24px;
    opacity: 0;
    transition: opacity 0.25s, transform 0.25s;
    z-index: 9999;
    pointer-events: none;
  }
  .pe__toast--show { opacity: 1; transform: translateX(-50%) translateY(0); }

  @media (max-width: 989px) {
    .pe { padding: 24px 24px 60px; }
    .pe__layout { grid-template-columns: 1fr; gap: 32px; }
    .pe__gallery { position: static; }
    .pe__sticky-bar { padding: 12px 16px; }
  }
  @media (max-width: 749px) {
    .pe { padding: 16px 16px 48px; }
    .pe__size-modal-inner { padding: 32px 24px; }
  }
</style>

{% schema %}
{
  "name": "Product Enhanced",
  "tag": "div",
  "class": "product-enhanced-section",
  "settings": [
    { "type": "checkbox", "id": "show_size_guide", "label": "Show size guide button", "default": true },
    { "type": "checkbox", "id": "show_tabs", "label": "Use tabs for product info", "default": true }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Product tab",
      "settings": [
        { "type": "text", "id": "title", "label": "Tab title", "default": "Description" },
        { "type": "richtext", "id": "content", "label": "Tab content", "default": "<p>Product description goes here.</p>" }
      ]
    },
    {
      "type": "size_guide",
      "name": "Size guide",
      "limit": 1,
      "settings": [
        { "type": "richtext", "id": "content", "label": "Size guide content", "default": "<p>Size guide table.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Enhanced",
      "blocks": [
        { "type": "tab", "settings": { "title": "Description", "content": "<p>Premium quality underwear crafted from sustainably sourced materials.</p>" } },
        { "type": "tab", "settings": { "title": "Care", "content": "<p>Machine wash cold. Tumble dry low. Do not bleach.</p>" } },
        { "type": "tab", "settings": { "title": "Shipping", "content": "<p>Free shipping on orders over $50. Delivered within 2-4 business days.</p>" } },
        { "type": "size_guide", "settings": { "content": "<table><tr><th>Size</th><th>Waist (cm)</th><th>Hip (cm)</th></tr><tr><td>XS</td><td>68–74</td><td>84–90</td></tr><tr><td>S</td><td>74–80</td><td>90–96</td></tr><tr><td>M</td><td>80–86</td><td>96–102</td></tr><tr><td>L</td><td>86–92</td><td>102–108</td></tr><tr><td>XL</td><td>92–98</td><td>108–114</td></tr></table>" } }
      ]
    }
  ],
  "templates": ["product"]
}
{% endschema %}
