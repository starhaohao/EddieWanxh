{%- comment -%}
  Sale Banner — editorial full-width promo header
  Matches the MrPorter "UP TO 50% OFF" style.
  v2: font picker · font size (desktop/mobile) · full position control (H+V, desktop/mobile)
{%- endcomment -%}

{%- liquid
  assign font = section.settings.headline_font

  assign dh = section.settings.desktop_h_align
  assign dv = section.settings.desktop_v_align
  assign mh = section.settings.mobile_h_align
  assign mv = section.settings.mobile_v_align

  case dh
    when 'left'
      assign d_items = 'flex-start'
      assign d_text  = 'left'
      assign d_pills = 'flex-start'
    when 'right'
      assign d_items = 'flex-end'
      assign d_text  = 'right'
      assign d_pills = 'flex-end'
    else
      assign d_items = 'center'
      assign d_text  = 'center'
      assign d_pills = 'center'
  endcase

  case dv
    when 'top'
      assign d_justify = 'flex-start'
    when 'bottom'
      assign d_justify = 'flex-end'
    else
      assign d_justify = 'center'
  endcase

  case mh
    when 'left'
      assign m_items = 'flex-start'
      assign m_text  = 'left'
      assign m_pills = 'flex-start'
    when 'right'
      assign m_items = 'flex-end'
      assign m_text  = 'right'
      assign m_pills = 'flex-end'
    else
      assign m_items = 'center'
      assign m_text  = 'center'
      assign m_pills = 'center'
  endcase

  case mv
    when 'top'
      assign m_justify = 'flex-start'
    when 'bottom'
      assign m_justify = 'flex-end'
    else
      assign m_justify = 'center'
  endcase
-%}

{%- style -%}
  {{ font | font_face: font_display: 'swap' }}

  #SaleBanner-{{ section.id }} {
    --sb-from:   {{ section.settings.gradient_from }};
    --sb-to:     {{ section.settings.gradient_to }};
    --sb-mid:    {{ section.settings.gradient_mid }};
    --sb-text:   {{ section.settings.text_color }};
    --sb-pill:   {{ section.settings.pill_color }};
    --sb-terms:  {{ section.settings.terms_color }};

    position: relative;
    width: 100%;
    overflow: hidden;
    min-height: {{ section.settings.desktop_min_height }}px;
    padding: {{ section.settings.padding_top }}px clamp(20px,5vw,72px) {{ section.settings.padding_bottom }}px;

    /* Flex: vertical (justify) + horizontal (align-items) for desktop */
    display: flex;
    flex-direction: column;
    justify-content: {{ d_justify }};
    align-items: {{ d_items }};

    /* Painterly gradient background */
    background:
      radial-gradient(ellipse 80% 120% at 0% 40%,   rgba(180,60,30,.55)  0%, transparent 55%),
      radial-gradient(ellipse 60% 80%  at 100% 60%,  rgba(140,30,20,.70)  0%, transparent 52%),
      radial-gradient(ellipse 100% 100% at 50% 50%,  var(--sb-mid)        0%, var(--sb-to) 100%);
    background-color: var(--sb-from);
  }

  /* Noise texture overlay */
  #SaleBanner-{{ section.id }}::before {
    content: '';
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.08'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    opacity: 0.18;
  }

  /* Optional background image */
  #SaleBanner-{{ section.id }} .sb-img {
    position: absolute; inset: 0; z-index: 0;
  }
  #SaleBanner-{{ section.id }} .sb-img img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    opacity: {{ section.settings.image_opacity | divided_by: 100.0 }};
    mix-blend-mode: multiply;
  }

  /* Content wrapper */
  #SaleBanner-{{ section.id }} .sb-inner {
    position: relative; z-index: 2;
    width: 100%;
    max-width: 1100px;
    display: flex;
    flex-direction: column;
    align-items: {{ d_items }};
    text-align: {{ d_text }};
  }

  /* Headline */
  #SaleBanner-{{ section.id }} .sb-headline {
    font-family: {{ font.family }}, {{ font.fallback_families }};
    font-weight: {{ font.weight }};
    font-style: {{ font.style }};
    font-size: {{ section.settings.headline_size_desktop }}px;
    letter-spacing: {{ section.settings.headline_tracking }}em;
    line-height: 0.92;
    color: var(--sb-text);
    margin: 0 0 clamp(6px, 1.2vw, 16px);
    text-transform: {{ section.settings.headline_case }};
    text-shadow: 0 2px 40px rgba(0,0,0,.25);
  }

  /* "SALE" sub-label */
  #SaleBanner-{{ section.id }} .sb-label {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(10px, 1.4vw, 14px);
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--sb-text);
    margin: 0 0 clamp(18px, 3vw, 36px);
    opacity: 0.88;
  }

  /* Category pills */
  #SaleBanner-{{ section.id }} .sb-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: {{ d_pills }};
    gap: 8px;
    margin: 0 0 clamp(14px, 2.2vw, 24px);
    width: 100%;
  }
  #SaleBanner-{{ section.id }} .sb-pill {
    display: inline-flex;
    align-items: center;
    padding: 9px 18px;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(10px, 1.2vw, 13px);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--sb-pill);
    border: 1px solid var(--sb-pill);
    border-radius: 2px;
    text-decoration: none;
    background: transparent;
    transition: background 0.18s ease, color 0.18s ease;
    white-space: nowrap;
    opacity: 0.88;
  }
  #SaleBanner-{{ section.id }} .sb-pill:hover {
    background: var(--sb-pill);
    color: {{ section.settings.gradient_from }};
    opacity: 1;
  }
  #SaleBanner-{{ section.id }} .sb-pill--active {
    background: var(--sb-pill);
    color: {{ section.settings.gradient_from }};
    opacity: 1;
  }

  /* Terms */
  #SaleBanner-{{ section.id }} .sb-terms {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(10px, 1.1vw, 12px);
    letter-spacing: 0.03em;
    color: var(--sb-terms);
    margin: 0;
    opacity: 0.72;
  }
  #SaleBanner-{{ section.id }} .sb-terms a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── Mobile overrides ── */
  @media (max-width: 749px) {
    #SaleBanner-{{ section.id }} {
      min-height: {{ section.settings.mobile_min_height }}px;
      justify-content: {{ m_justify }};
      align-items: {{ m_items }};
    }
    #SaleBanner-{{ section.id }} .sb-inner {
      align-items: {{ m_items }};
      text-align: {{ m_text }};
    }
    #SaleBanner-{{ section.id }} .sb-headline {
      font-size: {{ section.settings.headline_size_mobile }}px;
    }
    #SaleBanner-{{ section.id }} .sb-pills {
      justify-content: {{ m_pills }};
    }
    #SaleBanner-{{ section.id }} .sb-pill {
      font-size: 11px;
      padding: 8px 14px;
    }
  }
{%- endstyle -%}

<div id="SaleBanner-{{ section.id }}">
  {%- if section.settings.bg_image != blank -%}
    <div class="sb-img">
      {{ section.settings.bg_image | image_url: width: 2400 | image_tag: loading: 'lazy', sizes: '100vw' }}
    </div>
  {%- endif -%}

  <div class="sb-inner">

    {%- if section.settings.headline != blank -%}
      <h2 class="sb-headline">{{ section.settings.headline }}</h2>
    {%- endif -%}

    {%- if section.settings.sub_label != blank -%}
      <p class="sb-label">{{ section.settings.sub_label }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="sb-pills">
        {%- for block in section.blocks -%}
          {%- if block.settings.label != blank -%}
            <a href="{{ block.settings.url | default: '#' }}"
               class="sb-pill{% if block.settings.active %} sb-pill--active{% endif %}"
               {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.terms != blank -%}
      <p class="sb-terms">{{ section.settings.terms }}</p>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Sale Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Text" },
    { "type": "text", "id": "headline", "label": "Main headline", "default": "Up to 50% Off" },
    { "type": "text", "id": "sub_label", "label": "Label below headline", "default": "Sale" },
    { "type": "text", "id": "terms", "label": "Terms line", "default": "Terms and conditions apply" },

    { "type": "header", "content": "Headline font" },
    { "type": "font_picker", "id": "headline_font", "label": "Font", "default": "sans-serif" },
    {
      "type": "select", "id": "headline_case", "label": "Text case",
      "options": [
        { "value": "uppercase", "label": "UPPERCASE" },
        { "value": "capitalize", "label": "Capitalize" },
        { "value": "none", "label": "As typed" }
      ],
      "default": "uppercase"
    },
    { "type": "range", "id": "headline_tracking", "min": -5, "max": 20, "step": 1, "unit": "em", "label": "Letter spacing (×0.01)", "default": -1, "info": "-1 = -0.01em tight · 0 = normal · 10 = 0.10em wide" },

    { "type": "header", "content": "Font size" },
    { "type": "range", "id": "headline_size_desktop", "min": 32, "max": 160, "step": 4, "unit": "px", "label": "Desktop font size", "default": 104 },
    { "type": "range", "id": "headline_size_mobile", "min": 24, "max": 96, "step": 4, "unit": "px", "label": "Mobile font size", "default": 52 },

    { "type": "header", "content": "Desktop position" },
    {
      "type": "select", "id": "desktop_h_align", "label": "Horizontal",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select", "id": "desktop_v_align", "label": "Vertical",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "middle"
    },
    { "type": "range", "id": "desktop_min_height", "min": 100, "max": 700, "step": 20, "unit": "px", "label": "Min height", "default": 200 },

    { "type": "header", "content": "Mobile position" },
    {
      "type": "select", "id": "mobile_h_align", "label": "Horizontal",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select", "id": "mobile_v_align", "label": "Vertical",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "middle"
    },
    { "type": "range", "id": "mobile_min_height", "min": 100, "max": 500, "step": 20, "unit": "px", "label": "Min height", "default": 160 },

    { "type": "header", "content": "Background image (optional)" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "range", "id": "image_opacity", "min": 10, "max": 100, "step": 5, "unit": "%", "label": "Image opacity", "default": 55, "info": "Blends multiply over gradient" },

    { "type": "header", "content": "Gradient colors" },
    { "type": "color", "id": "gradient_from", "label": "Base / darkest color", "default": "#6b1a14" },
    { "type": "color", "id": "gradient_mid", "label": "Mid color", "default": "#923531" },
    { "type": "color", "id": "gradient_to", "label": "Edge / fade color", "default": "#4a0e0b" },

    { "type": "header", "content": "Text colors" },
    { "type": "color", "id": "text_color", "label": "Headline color", "default": "#ffffff" },
    { "type": "color", "id": "pill_color", "label": "Pill border & text", "default": "#ffffff" },
    { "type": "color", "id": "terms_color", "label": "Terms text", "default": "#ffffff" },

    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Top", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Bottom", "default": 56 }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Category pill",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "All Sale" },
        { "type": "url", "id": "url", "label": "Link" },
        { "type": "checkbox", "id": "active", "label": "Highlight as active", "default": false }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Sale Banner",
      "settings": {
        "headline": "Up to 50% Off",
        "sub_label": "Sale",
        "terms": "Terms and conditions apply"
      },
      "blocks": [
        { "type": "pill", "settings": { "label": "All Sale", "active": true } },
        { "type": "pill", "settings": { "label": "T-Shirts" } },
        { "type": "pill", "settings": { "label": "Briefs" } },
        { "type": "pill", "settings": { "label": "Boxer Trunks" } },
        { "type": "pill", "settings": { "label": "Socks" } }
      ]
    }
  ]
}
{% endschema %}
