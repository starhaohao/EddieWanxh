<section class="rms" style="--rms-bg:{{ section.settings.bg_color }};--rms-text:{{ section.settings.text_color }};">
  {%- for block in section.blocks -%}
    {%- if block.type == 'deal' -%}
      <div class="rms__item" {{ block.shopify_attributes }}>
        <span class="rms__qty">{{ block.settings.quantity }}</span>
        <span class="rms__label">{{ block.settings.label }}</span>
      </div>
      {%- unless forloop.last -%}<div class="rms__div"></div>{%- endunless -%}
    {%- elsif block.type == 'note' -%}
      <div class="rms__note" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
    {%- endif -%}
  {%- endfor -%}
</section>

<style>
  .rms {
    background: var(--rms-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
    padding: 13px 32px;
    flex-wrap: wrap;
    border-bottom: 1px solid rgba(23,25,28,.12);
  }
  .rms__item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: monospace;
    font-size: 10px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--rms-text);
    opacity: .85;
  }
  .rms__qty {
    font-weight: 600;
    opacity: 1;
    color: var(--rms-text);
  }
  .rms__label {
    opacity: .75;
  }
  .rms__div {
    width: 1px;
    height: 10px;
    background: rgba(23,25,28,.2);
    flex-shrink: 0;
  }
  .rms__note {
    font-family: monospace;
    font-size: 10px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--rms-text);
    opacity: .6;
  }

  @media (max-width: 749px) {
    .rms { gap: 12px; padding: 11px 16px; }
    .rms__div { display: none; }
  }
</style>

{% schema %}
{
  "name": "Rotation Mechanic Strip",
  "tag": "div",
  "class": "rotation-mechanic-strip-section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#AAC9E3" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#17191C" }
  ],
  "blocks": [
    {
      "type": "deal",
      "name": "Deal",
      "settings": [
        { "type": "text", "id": "quantity", "label": "Quantity / bold text", "default": "3 pairs" },
        { "type": "text", "id": "label", "label": "Label", "default": "· 15% off" }
      ]
    },
    {
      "type": "note",
      "name": "Note",
      "settings": [
        { "type": "text", "id": "text", "label": "Note text", "default": "Applied automatically at checkout · No code required" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rotation Mechanic Strip",
      "blocks": [
        { "type": "deal", "settings": { "quantity": "3 pairs", "label": "· 15% off" } },
        { "type": "deal", "settings": { "quantity": "5 pairs", "label": "· 25% off" } },
        { "type": "note", "settings": { "text": "Applied automatically at checkout · No code required" } }
      ]
    }
  ],
  "templates": ["page"]
}
{% endschema %}
