{%- liquid
  assign columns = section.settings.columns
  assign show_filters = section.settings.show_filter_bar
  assign products_per_page = section.settings.products_per_page | default: 12
-%}

{%- paginate collection.products by products_per_page -%}

<section class="cqa" style="--cqa-cols:{{ columns }};">

  {%- if show_filters -%}
    <div class="cqa__bar">
      <div class="cqa__bar-left">
        <span class="cqa__count">{{ collection.products_count }} Products</span>
      </div>
      <div class="cqa__bar-right">
        <label class="cqa__sort-label" for="cqa-sort-{{ section.id }}">Sort</label>
        <select class="cqa__sort" id="cqa-sort-{{ section.id }}" onchange="window.location.href=this.value">
          {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
          {%- for option in collection.sort_options -%}
            <option value="{{ collection.url }}?sort_by={{ option.value }}"{% if option.value == sort_by %} selected{% endif %}>{{ option.name }}</option>
          {%- endfor -%}
        </select>
      </div>
    </div>
  {%- endif -%}

  <div class="cqa__grid">
    {%- for product in collection.products -%}
      <div class="cqa__item" data-product-id="{{ product.id }}">
        <a class="cqa__img-link" href="{{ product.url }}">
          <div class="cqa__img-wrap">
            {%- if product.featured_image -%}
              <img class="cqa__img cqa__img--main"
                src="{{ product.featured_image | image_url: width: 900 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="lazy" width="900">
              {%- if product.images[1] != blank -%}
                <img class="cqa__img cqa__img--hover"
                  src="{{ product.images[1] | image_url: width: 900 }}"
                  alt="{{ product.images[1].alt | escape }}"
                  loading="lazy" width="900">
              {%- endif -%}
            {%- else -%}
              <div class="cqa__img cqa__img--placeholder"></div>
            {%- endif -%}

            {%- if product.compare_at_price > product.price -%}
              <div class="cqa__badge cqa__badge--sale">Sale</div>
            {%- elsif product.tags contains 'new' -%}
              <div class="cqa__badge cqa__badge--new">New</div>
            {%- endif -%}
          </div>
        </a>

        <div class="cqa__quick-add" data-product-url="{{ product.url }}.js">
          {%- assign size_option = product.options_with_values | where: 'name', 'Size' | first -%}
          {%- if size_option -%}
            <div class="cqa__sizes">
              {%- for value in size_option.values -%}
                {%- liquid
                  assign variant_available = false
                  for variant in product.variants
                    if variant.option1 == value or variant.option2 == value or variant.option3 == value
                      if variant.available
                        assign variant_available = true
                      endif
                      assign variant_id = variant.id
                    endif
                  endfor
                -%}
                <button
                  class="cqa__size{% unless variant_available %} cqa__size--oos{% endunless %}"
                  data-variant-id="{{ variant_id }}"
                  data-product-id="{{ product.id }}"
                  {% unless variant_available %}disabled{% endunless %}>
                  {{ value }}
                </button>
              {%- endfor -%}
            </div>
          {%- else -%}
            <button class="cqa__add-btn"
              data-variant-id="{{ product.first_available_variant.id }}"
              data-product-id="{{ product.id }}">
              Add to Cart
            </button>
          {%- endif -%}
        </div>

        <div class="cqa__info">
          <a class="cqa__name" href="{{ product.url }}">{{ product.title }}</a>
          <div class="cqa__price">
            {%- if product.compare_at_price > product.price -%}
              <span class="cqa__price--compare">{{ product.compare_at_price | money }}</span>
            {%- endif -%}
            <span class="cqa__price--current">{{ product.price | money }}</span>
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    <div class="cqa__pagination">
      {%- if paginate.previous -%}
        <a class="cqa__page-btn" href="{{ paginate.previous.url }}">← Prev</a>
      {%- endif -%}
      <span class="cqa__page-info">{{ paginate.current_page }} / {{ paginate.pages }}</span>
      {%- if paginate.next -%}
        <a class="cqa__page-btn" href="{{ paginate.next.url }}">Next →</a>
      {%- endif -%}
    </div>
  {%- endif -%}

</section>

{%- endpaginate -%}

<div class="cqa__toast" id="cqa-toast" aria-live="polite"></div>

<script>
(function() {
  function addToCart(variantId, btn) {
    if (!variantId) return;
    var origText = btn.textContent;
    btn.textContent = '...';
    btn.disabled = true;

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      showToast(data.title ? data.title + ' added to cart' : 'Added to cart');
      btn.textContent = '✓ Added';
      setTimeout(function() {
        btn.textContent = origText;
        btn.disabled = false;
      }, 2000);
      document.dispatchEvent(new CustomEvent('cart:refresh'));
    })
    .catch(function() {
      btn.textContent = origText;
      btn.disabled = false;
    });
  }

  function showToast(msg) {
    var toast = document.getElementById('cqa-toast');
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('cqa__toast--show');
    clearTimeout(toast._t);
    toast._t = setTimeout(function() { toast.classList.remove('cqa__toast--show'); }, 2500);
  }

  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.cqa__size:not([disabled]), .cqa__add-btn:not([disabled])');
    if (!btn) return;
    addToCart(btn.dataset.variantId, btn);
  });
})();
</script>

<style>
  .cqa {
    background: #faf9f7;
    padding: 0 48px 80px;
  }
  .cqa__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    margin-bottom: 32px;
  }
  .cqa__count {
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #888;
  }
  .cqa__bar-right { display: flex; align-items: center; gap: 10px; }
  .cqa__sort-label {
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #888;
  }
  .cqa__sort {
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    color: #111;
    border: 1px solid #ddd;
    background: #fff;
    padding: 6px 10px;
    cursor: pointer;
  }
  .cqa__grid {
    display: grid;
    grid-template-columns: repeat(var(--cqa-cols), 1fr);
    gap: 24px 16px;
  }
  .cqa__item { position: relative; }
  .cqa__img-link { display: block; text-decoration: none; }
  .cqa__img-wrap {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #f0ede8;
  }
  .cqa__img {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: opacity 0.4s, transform 0.55s cubic-bezier(0.25,0,0,1);
    display: block;
  }
  .cqa__img--hover { opacity: 0; }
  .cqa__img-link:hover .cqa__img--main { opacity: 0; transform: scale(1.03); }
  .cqa__img-link:hover .cqa__img--hover { opacity: 1; }
  .cqa__img--placeholder { background: #e8e4de; position: absolute; inset: 0; }
  .cqa__badge {
    position: absolute;
    top: 12px; left: 12px;
    font-family: monospace;
    font-size: 8px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 4px 8px;
  }
  .cqa__badge--sale { background: #922; color: #fff; }
  .cqa__badge--new { background: #111; color: #fff; }
  .cqa__quick-add {
    position: absolute;
    bottom: 52px;
    left: 0; right: 0;
    padding: 0 4px;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.25s, transform 0.25s;
    pointer-events: none;
  }
  .cqa__item:hover .cqa__quick-add {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .cqa__sizes {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    background: rgba(255,255,255,0.96);
    padding: 8px;
    backdrop-filter: blur(4px);
  }
  .cqa__size {
    flex: 1;
    min-width: 36px;
    padding: 8px 4px;
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid #ddd;
    background: #fff;
    color: #111;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    text-align: center;
  }
  .cqa__size:hover:not([disabled]) { background: #111; color: #fff; border-color: #111; }
  .cqa__size--oos {
    opacity: 0.35;
    text-decoration: line-through;
    cursor: not-allowed;
  }
  .cqa__add-btn {
    width: 100%;
    padding: 12px;
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    background: #111;
    color: #fff;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }
  .cqa__add-btn:hover { background: #333; }
  .cqa__info {
    padding: 12px 4px 0;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
  }
  .cqa__name {
    font-size: 13px;
    letter-spacing: -0.01em;
    color: #111;
    text-decoration: none;
    line-height: 1.3;
  }
  .cqa__name:hover { text-decoration: underline; }
  .cqa__price {
    font-family: monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #111;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .cqa__price--compare {
    text-decoration: line-through;
    color: #aaa;
    margin-right: 4px;
  }
  .cqa__pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin-top: 60px;
  }
  .cqa__page-btn {
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: #111;
    border-bottom: 1px solid #111;
    padding-bottom: 2px;
  }
  .cqa__page-info {
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    color: #888;
  }
  .cqa__toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(16px);
    background: #111;
    color: #fff;
    font-family: monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 12px 24px;
    opacity: 0;
    transition: opacity 0.25s, transform 0.25s;
    z-index: 9999;
    pointer-events: none;
  }
  .cqa__toast--show { opacity: 1; transform: translateX(-50%) translateY(0); }
  @media (max-width: 989px) {
    .cqa { padding: 0 24px 60px; }
    .cqa__grid { grid-template-columns: repeat(2, 1fr); gap: 16px 12px; }
    .cqa__quick-add { opacity: 1; transform: none; pointer-events: auto; }
  }
  @media (max-width: 749px) {
    .cqa { padding: 0 12px 48px; }
  }
</style>

{% schema %}
{
  "name": "Collection Quick-Add",
  "tag": "div",
  "class": "collection-quick-add-section",
  "settings": [
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 8, "max": 48, "step": 4, "default": 12 },
    { "type": "checkbox", "id": "show_filter_bar", "label": "Show sort bar", "default": true }
  ],
  "presets": [
    { "name": "Collection Quick-Add" }
  ],
  "templates": ["collection"]
}
{% endschema %}
