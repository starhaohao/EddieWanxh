{%- liquid
  assign socks_url   = section.settings.socks_url | default: '/collections/socks'
  assign badge_text  = section.settings.badge_text | default: 'free gift'
  assign heading     = section.settings.heading    | default: 'buy any 2 items'
  assign subheading  = section.settings.subheading | default: 'get a free pair of L Cotton Spandex Socks'
  assign code        = section.settings.code       | default: 'freesocks26'
  assign note        = section.settings.note       | default: 'choose your shade at checkout'
  assign shade_1     = section.settings.shade_1    | default: 'Black'
  assign shade_2     = section.settings.shade_2    | default: 'Dusty Blue'
  assign shade_3     = section.settings.shade_3    | default: 'Pink'
  assign shade_4     = section.settings.shade_4    | default: 'Heather Grey'
  assign show_cart_nudge = section.settings.show_cart_nudge
-%}

<div class="fs26" id="fs26-{{ section.id }}"
     data-code="{{ code }}"
     data-min-qty="{{ section.settings.min_qty | default: 2 }}"
     data-socks-url="{{ socks_url }}">

  {%- if badge_text != blank -%}
    <span class="fs26__badge">{{ badge_text }}</span>
  {%- endif -%}

  <div class="fs26__body">
    <div class="fs26__text">
      <p class="fs26__heading">{{ heading }}</p>
      <p class="fs26__sub">{{ subheading }}</p>
      <div class="fs26__shades" aria-label="Available shades">
        {%- if shade_1 != blank -%}<span class="fs26__shade fs26__shade--black" title="{{ shade_1 }}"></span>{%- endif -%}
        {%- if shade_2 != blank -%}<span class="fs26__shade fs26__shade--blue"  title="{{ shade_2 }}"></span>{%- endif -%}
        {%- if shade_3 != blank -%}<span class="fs26__shade fs26__shade--pink"  title="{{ shade_3 }}"></span>{%- endif -%}
        {%- if shade_4 != blank -%}<span class="fs26__shade fs26__shade--grey"  title="{{ shade_4 }}"></span>{%- endif -%}
      </div>
    </div>
    <div class="fs26__right">
      <button class="fs26__code" data-copy="{{ code }}" aria-label="Copy discount code {{ code }}">
        <span class="fs26__code-label">code</span>
        <span class="fs26__code-val">{{ code }}</span>
        <span class="fs26__code-copied" aria-live="polite">copied</span>
      </button>
      {%- if note != blank -%}
        <p class="fs26__note">{{ note }}</p>
      {%- endif -%}
    </div>
  </div>

</div>

{%- if show_cart_nudge -%}
<div class="fs26-nudge" id="fs26-nudge-{{ section.id }}" aria-live="polite" hidden>
  <span class="fs26-nudge__icon">🎁</span>
  <span class="fs26-nudge__text">add <strong>1 more item</strong> to unlock free socks — use <em>{{ code }}</em></span>
  <a class="fs26-nudge__cta" href="{{ socks_url }}">pick your shade →</a>
</div>
{%- endif -%}

<style>
  .fs26 {
    --fs26-bg:      #1a1a1a;
    --fs26-border:  rgba(255,255,255,0.1);
    --fs26-text:    #fff;
    --fs26-muted:   rgba(255,255,255,0.45);
    --fs26-accent:  #923531;
    --fs26-mono:    'IBM Plex Sans', 'Helvetica Neue', Helvetica, sans-serif;
    position: relative;
    border: 1px solid var(--fs26-border);
    padding: 18px 20px;
    margin: 20px 0;
    background: var(--fs26-bg);
  }

  .fs26__badge {
    position: absolute;
    top: 0; right: 0;
    background: var(--fs26-accent);
    color: #fff;
    font-family: var(--fs26-mono);
    font-size: 8px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 4px 10px;
  }

  .fs26__body {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    flex-wrap: wrap;
  }

  .fs26__text { flex: 1; min-width: 160px; }

  .fs26__heading {
    font-size: 16px;
    letter-spacing: -0.02em;
    color: var(--fs26-text);
    margin: 0 0 4px;
  }

  .fs26__sub {
    font-family: var(--fs26-mono);
    font-size: 11px;
    color: var(--fs26-muted);
    margin: 0 0 12px;
    letter-spacing: 0.01em;
    line-height: 1.5;
  }

  .fs26__shades {
    display: flex;
    gap: 7px;
    align-items: center;
  }

  .fs26__shade {
    display: inline-block;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
  }
  .fs26__shade--black { background: #1a1a1a; border-color: rgba(255,255,255,0.35); }
  .fs26__shade--blue  { background: #7a9bb5; }
  .fs26__shade--pink  { background: #d4a0a0; }
  .fs26__shade--grey  { background: #9e9e9e; }

  .fs26__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    flex-shrink: 0;
  }

  .fs26__code {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    border: 1px dashed rgba(255,255,255,0.3);
    background: transparent;
    color: var(--fs26-text);
    padding: 8px 18px;
    cursor: pointer;
    transition: border-color 0.2s;
    font-family: var(--fs26-mono);
    min-width: 110px;
  }
  .fs26__code:hover { border-color: rgba(255,255,255,0.6); }
  .fs26__code:hover .fs26__code-val { text-decoration: underline; }

  .fs26__code-label {
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--fs26-muted);
  }
  .fs26__code-val {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .fs26__code-copied {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--fs26-accent);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }
  .fs26__code.is-copied .fs26__code-copied { opacity: 1; }

  .fs26__note {
    font-family: var(--fs26-mono);
    font-size: 9px;
    color: var(--fs26-muted);
    text-align: right;
    margin: 0;
    letter-spacing: 0.02em;
  }

  /* cart nudge */
  .fs26-nudge {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(146,53,49,0.12);
    border: 1px solid rgba(146,53,49,0.35);
    padding: 12px 16px;
    margin: 12px 0 0;
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 12px;
    color: rgba(255,255,255,0.75);
    flex-wrap: wrap;
  }
  .fs26-nudge[hidden] { display: none; }
  .fs26-nudge__icon { font-size: 16px; flex-shrink: 0; }
  .fs26-nudge__text { flex: 1; line-height: 1.5; }
  .fs26-nudge__text strong { color: #fff; font-weight: 600; }
  .fs26-nudge__text em { font-style: normal; letter-spacing: 0.04em; color: #fff; }
  .fs26-nudge__cta {
    color: #fff;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.4);
    flex-shrink: 0;
  }
  .fs26-nudge__cta:hover { border-bottom-color: #fff; }

  @media screen and (max-width: 749px) {
    .fs26__body { flex-direction: column; gap: 14px; }
    .fs26__right { align-items: flex-start; }
    .fs26__note { text-align: left; }
  }
</style>

<script>
(function () {
  var wrap     = document.getElementById('fs26-{{ section.id }}');
  var nudge    = document.getElementById('fs26-nudge-{{ section.id }}');
  var codeBtn  = wrap && wrap.querySelector('.fs26__code');
  var minQty   = {{ section.settings.min_qty | default: 2 }};

  /* ── Copy code ── */
  if (codeBtn) {
    codeBtn.addEventListener('click', function () {
      var code = codeBtn.dataset.copy;
      if (!code) return;
      navigator.clipboard && navigator.clipboard.writeText(code).then(function () {
        codeBtn.classList.add('is-copied');
        setTimeout(function () { codeBtn.classList.remove('is-copied'); }, 1800);
      });
    });
  }

  /* ── Cart nudge: show when cart has exactly 1 item ── */
  if (nudge) {
    function checkCart() {
      fetch('/cart.js')
        .then(function (r) { return r.json(); })
        .then(function (cart) {
          var count = cart.item_count || 0;
          if (count > 0 && count < minQty) {
            nudge.removeAttribute('hidden');
          } else {
            nudge.setAttribute('hidden', '');
          }
        })
        .catch(function () {});
    }

    checkCart();
    document.addEventListener('cart:updated', checkCart);
  }
})();
</script>

{% schema %}
{
  "name": "Free Socks Promo — freesocks26",
  "tag": "div",
  "class": "shopify-section--freesocks26",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge label",
      "default": "free gift"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "buy any 2 items"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "get a free pair of L Cotton Spandex Socks"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Fine print",
      "default": "choose your shade at checkout"
    },
    {
      "type": "text",
      "id": "code",
      "label": "Discount code",
      "default": "freesocks26"
    },
    {
      "type": "number",
      "id": "min_qty",
      "label": "Minimum cart quantity",
      "default": 2
    },
    {
      "type": "url",
      "id": "socks_url",
      "label": "Socks collection URL"
    },
    {
      "type": "header",
      "content": "Shade swatches"
    },
    {
      "type": "text",
      "id": "shade_1",
      "label": "Shade 1",
      "default": "Black"
    },
    {
      "type": "text",
      "id": "shade_2",
      "label": "Shade 2",
      "default": "Dusty Blue"
    },
    {
      "type": "text",
      "id": "shade_3",
      "label": "Shade 3",
      "default": "Pink"
    },
    {
      "type": "text",
      "id": "shade_4",
      "label": "Shade 4",
      "default": "Heather Grey"
    },
    {
      "type": "header",
      "content": "Cart nudge"
    },
    {
      "type": "checkbox",
      "id": "show_cart_nudge",
      "label": "Show cart nudge when under minimum quantity",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Free Socks Promo — freesocks26"
    }
  ]
}
{% endschema %}
