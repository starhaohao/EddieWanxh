{%- liquid
  assign pf_bg = section.settings.background_color
  assign pf_text = section.settings.text_color
  assign pf_accent = section.settings.accent_color
  assign pf_padding = section.settings.padding
-%}

<section class="pf" style="--pf-bg: {{ pf_bg }}; --pf-text: {{ pf_text }}; --pf-accent: {{ pf_accent }}; --pf-p: {{ pf_padding }}px;">
  <div class="pf__container">
    <div class="pf__content">
      <div class="pf__icon">
        <svg viewBox="0 0 24 24" width="48" height="48" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>
        </svg>
      </div>
      <h2 class="pf__title">{{ section.settings.title }}</h2>
      <p class="pf__subtitle">{{ section.settings.subtitle }}</p>
      <div class="pf__offer">
        <p class="pf__offer-label">{{ section.settings.offer_label }}</p>
        <p class="pf__offer-code">{{ section.settings.offer_code }}</p>
      </div>
      <p class="pf__description">{{ section.settings.description }}</p>
      {%- if section.settings.cta_text -%}
        <a href="{{ section.settings.cta_link }}" class="pf__button">{{ section.settings.cta_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .pf {
    background: var(--pf-bg);
    color: var(--pf-text);
    padding: var(--pf-p);
  }

  .pf__container {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 40px;
  }

  @media (max-width: 749px) {
    .pf__container {
      padding: 0 20px;
    }
  }

  .pf__content {
    text-align: center;
  }

  .pf__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    margin: 0 auto 24px;
    opacity: 0.8;
  }

  .pf__title {
    font-family: Galdeano, 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 32px;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
    color: inherit;
  }

  .pf__subtitle {
    font-family: 'IBM Plex Sans', Helvetica, Arial, sans-serif;
    font-size: 14px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.6;
    margin: 0 0 28px;
  }

  .pf__offer {
    background: rgba(0, 0, 0, 0.05);
    padding: 20px 24px;
    margin: 0 0 28px;
    border-radius: 4px;
  }

  .pf__offer-label {
    font-family: 'IBM Plex Sans', Helvetica, Arial, sans-serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.6;
    margin: 0 0 8px;
  }

  .pf__offer-code {
    font-family: 'IBM Plex Sans', Helvetica, Arial, sans-serif;
    font-size: 24px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0;
  }

  .pf__description {
    font-family: 'IBM Plex Sans', Helvetica, Arial, sans-serif;
    font-size: 14px;
    line-height: 1.6;
    margin: 0 0 32px;
    opacity: 0.8;
  }

  .pf__button {
    display: inline-block;
    background: var(--pf-accent);
    color: #fff;
    font-family: 'IBM Plex Sans', Helvetica, Arial, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 14px 32px;
    border-radius: 2px;
    transition: opacity 0.2s ease;
  }

  .pf__button:hover {
    opacity: 0.9;
  }

  @media (max-width: 749px) {
    .pf__title {
      font-size: 24px;
    }

    .pf__offer {
      padding: 16px 20px;
    }

    .pf__offer-code {
      font-size: 20px;
    }
  }
</style>

{% schema %}
{
  "name": "Free Socks Promo",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Get a Free Pair"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Special Offer"
    },
    {
      "type": "text",
      "id": "offer_label",
      "label": "Offer Label",
      "default": "Use Code"
    },
    {
      "type": "text",
      "id": "offer_code",
      "label": "Promo Code",
      "default": "FREESOCKS26"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Buy any 2 items, get a free pair of L Cotton Spandex Socks. Choose your shade at checkout."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text (Optional)",
      "default": "SHOP"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f0ede8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#212529"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Button Color",
      "default": "#212529"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Free Socks Promo"
    }
  ]
}
{% endschema %}
