{%- comment -%}
══════════════════════════════════════════════════════════════════
  TRIIIPLE · EMAIL 06 — SHIPPING CONFIRMATION
  Settings → Notifications → "Shipping confirmation" → Edit code
  This is a NOTIFICATION template — paste as the FULL email code.
──────────────────────────────────────────────────────────────────
  ARCHITECTURE: Shopify sends this email. Klaviyo syncs data only.

  LIQUID RULES THIS FILE DEMONSTRATES:
  1. Order fields are TOP-LEVEL here: {{ name }}, {{ order_status_url }}
     — NOT {{ order.name }}. (The `order` object is unnamed in email
     templates, per Shopify's notification reference.)
  2. {{ output }}      → prints a value
  3. {% logic %}       → if / for / assign (prints nothing itself)
  4. value | filter    → transforms a value (money, img_url, date…)
══════════════════════════════════════════════════════════════════
{%- endcomment -%}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Your order is on the way</title>
</head>
<body style="margin:0;padding:0;background:#15171a;">

{%- comment -%} ── design tokens (assign = make a variable) ── {%- endcomment -%}
{%- assign logo_url     = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/Frame_77.png?v=1775028055" -%}
{%- assign ic_facebook  = "PASTE_FACEBOOK_ICON_URL" -%}
{%- assign ic_instagram = "PASTE_INSTAGRAM_ICON_URL" -%}
{%- assign ic_pinterest = "PASTE_PINTEREST_ICON_URL" -%}
{%- assign ff = "'Helvetica Neue', Helvetica, Arial, sans-serif" -%}
{%- assign fm = "'Courier New', Courier, monospace" -%}
{%- assign fd = "Galdeano, 'Helvetica Neue', Helvetica, Arial, sans-serif" -%}

{%- comment -%}
  ── if / else: pick the tracking link when it exists, else fall back
  to the order status page. `.size` counts items in a list.
{%- endcomment -%}
{%- if fulfillment.tracking_urls.size > 0 -%}
  {%- assign track_url = fulfillment.tracking_urls.first -%}
{%- else -%}
  {%- assign track_url = order_status_url -%}
{%- endif -%}

<div style="display:none;max-height:0;overflow:hidden;opacity:0;mso-hide:all;">It just left the studio.&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;</div>

<table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="background:#15171a;">
<tr><td align="center" style="padding:24px 12px;">

  <table role="presentation" width="600" border="0" cellpadding="0" cellspacing="0" style="width:600px;max-width:600px;background:#212529;">

    <tr><td align="center" style="padding:48px 56px 0;">
      <img src="{{ logo_url }}" width="104" alt="TRIIIPLE" style="display:block;width:104px;height:auto;border:0;">
      <div style="font-family:{{ fm }};font-size:9px;letter-spacing:3px;text-transform:uppercase;color:#6c7178;padding-top:14px;">wear it, own it, explain nothing</div>
    </td></tr>

    <tr><td align="center" style="padding:52px 56px 0;">
      {%- comment -%} {{ name }} → e.g. "#1042"  (top-level order field) {%- endcomment -%}
      <div style="font-family:{{ fm }};font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#6c7178;padding-bottom:18px;">order {{ name }} · shipped</div>
      <div style="font-family:{{ fd }};font-size:46px;line-height:1.0;letter-spacing:-2px;color:#ffffff;">it's on<br>the way.</div>
      {%- comment -%} personalise with the shipping name {%- endcomment -%}
      <div style="font-family:{{ ff }};font-size:15px;line-height:1.75;color:#9aa0a6;padding:24px 0 0;">Hi {{ shipping_address.first_name }}, your order just left the studio. We'll keep tracking updated until it lands.</div>
    </td></tr>

    {%- comment -%} ── tracking card: only render if a number exists ── {%- endcomment -%}
    {%- if fulfillment.tracking_numbers.size > 0 -%}
    <tr><td style="padding:32px 56px 0;">
      <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="border:1px dashed #4a4f55;">
        <tr><td align="center" style="padding:20px;">
          <div style="font-family:{{ fm }};font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#9aa0a6;">tracking · {{ fulfillment.tracking_company }}</div>
          <div style="font-family:{{ fm }};font-size:20px;letter-spacing:2px;color:#ffffff;padding-top:8px;">{{ fulfillment.tracking_numbers.first }}</div>
        </td></tr>
      </table>
    </td></tr>
    {%- endif -%}

    {%- comment -%}
      ── for-loop over the items in THIS shipment ──
      `fulfillment.fulfillment_line_items` is a list; each entry (fl) has
      `.line_item` (the product) and `.quantity`. We assign li = fl.line_item
      so the markup reads cleanly. `| img_url: '160x'` resizes the photo.
    {%- endcomment -%}
    <tr><td style="padding:34px 56px 0;">
      <div style="font-family:{{ fm }};font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#6c7178;padding-bottom:6px;">in this shipment</div>
      <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0">
        {%- for fl in fulfillment.fulfillment_line_items -%}
        {%- assign li = fl.line_item -%}
        <tr>
          <td width="60" valign="middle" style="padding:14px 16px 14px 0;border-top:1px solid #2f3338;">
            <img src="{{ li.image | img_url: '160x' }}" width="60" alt="{{ li.title }}" style="display:block;width:60px;height:74px;border:0;background:#e9e8e4;">
          </td>
          <td valign="middle" style="padding:14px 0;border-top:1px solid #2f3338;">
            <div style="font-family:{{ fm }};font-size:8px;letter-spacing:1px;text-transform:uppercase;color:#6c7178;">{{ li.product.vendor | default: 'TRIIIPLE' }}</div>
            <div style="font-family:{{ fd }};font-size:16px;letter-spacing:-0.5px;color:#ececed;padding-top:2px;">{{ li.title }}</div>
          </td>
          <td valign="middle" align="right" style="padding:14px 0;border-top:1px solid #2f3338;font-family:{{ fm }};font-size:11px;letter-spacing:1px;color:#9aa0a6;white-space:nowrap;">×{{ fl.quantity }}</td>
        </tr>
        {%- endfor -%}
        <tr><td colspan="3" style="border-top:1px solid #2f3338;font-size:0;line-height:0;">&nbsp;</td></tr>
      </table>
    </td></tr>

    <tr><td align="center" style="padding:34px 56px 4px;">
      <table role="presentation" border="0" cellpadding="0" cellspacing="0" align="center">
        <tr><td align="center" bgcolor="#ffffff" style="background:#ffffff;">
          {%- comment -%} track_url was chosen by the if/else up top {%- endcomment -%}
          <a href="{{ track_url }}" style="display:inline-block;padding:18px 44px;font-family:{{ fm }};font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#212529;text-decoration:none;">track your order</a>
        </td></tr>
      </table>
    </td></tr>

    <tr><td style="padding:52px 0 0;">
      <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="background:#2a2e33;">
        <tr><td align="center" style="padding:36px 56px 40px;">
          <div style="font-family:{{ ff }};font-size:13px;line-height:1.65;color:#9aa0a6;max-width:340px;margin:0 auto;">Questions about your order? Reply, or reach us at <a href="mailto:info@triiiplestudio.com" style="color:#ececed;text-decoration:underline;">info@triiiplestudio.com</a>.</div>
          <div style="width:28px;height:1px;background:#383c41;margin:24px auto;font-size:0;line-height:0;">&nbsp;</div>
          <table role="presentation" border="0" cellpadding="0" cellspacing="0" align="center"><tr>
            <td style="padding:0 5px;"><a href="https://www.facebook.com/triiiplestudio"><img src="{{ ic_facebook }}" width="18" height="18" alt="Facebook" style="display:block;border:1px solid #383c41;padding:11px;background:#2a2e33;"></a></td>
            <td style="padding:0 5px;"><a href="https://www.instagram.com/triiiple_studio"><img src="{{ ic_instagram }}" width="18" height="18" alt="Instagram" style="display:block;border:1px solid #383c41;padding:11px;background:#2a2e33;"></a></td>
            <td style="padding:0 5px;"><a href="https://www.pinterest.com/triiiple_studio/"><img src="{{ ic_pinterest }}" width="18" height="18" alt="Pinterest" style="display:block;border:1px solid #383c41;padding:11px;background:#2a2e33;"></a></td>
          </tr></table>
          <img src="{{ logo_url }}" width="78" alt="TRIIIPLE" style="display:block;width:78px;height:auto;border:0;margin:28px auto 14px;opacity:0.7;">
          <div style="font-family:{{ fm }};font-size:9px;letter-spacing:1px;color:#6c7178;line-height:2;">© 2026 triiiple studio · singapore · sgd</div>
        </td></tr>
      </table>
    </td></tr>

  </table>

</td></tr>
</table>
</body>
</html>
