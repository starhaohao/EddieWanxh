{%- comment -%}
══════════════════════════════════════════════════════════════════
  TRIIIPLE · EMAIL 04 — WELCOME / NEW SUBSCRIBER
  Trigger: "Customer subscribes" / email-signup welcome automation
  Type: Shopify marketing email (double opt-in lead)
  Paste into: Settings → Notifications → "Customer subscribes" → Custom Liquid
──────────────────────────────────────────────────────────────────
  ARCHITECTURE: Shopify owns consent & sends this email.
  Klaviyo syncs the subscriber list only — no Klaviyo code here.

  Logo + banner are already wired to your CDN URLs.
  Still to fill: the 3 social icon URLs (upload social-*.png → Files).
  Codes shown: TRIIIPLE10 (10% off, min $35) · FREESOCKS (buy 3 get 1).
══════════════════════════════════════════════════════════════════
{%- endcomment -%}

{%- assign banner_url   = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/Banner_EDM_welcome.jpg?v=1780663731" -%}
{%- assign logo_url     = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/TRIIIPLE_LOGO_White.png?v=1760773519" -%}
{%- assign ic_facebook  = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/File_1.png?v=1780662733" -%}
{%- assign ic_instagram = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/File_4.png?v=1780662734" -%}
{%- assign ic_pinterest = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/File_4.png?v=1780662734" -%}

{%- assign ff = "'Helvetica Neue', Helvetica, Arial, sans-serif" -%}
{%- assign fm = "'Courier New', Courier, monospace" -%}
{%- assign fd = "Galdeano, 'Helvetica Neue', Helvetica, Arial, sans-serif" -%}

<div style="display:none;max-height:0;overflow:hidden;opacity:0;mso-hide:all;">You're on the list — here's 10% off and a free pair of socks.&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;</div>

<table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="background:#15171a;">
<tr><td align="center" style="padding:24px 12px;">

  <table role="presentation" width="600" border="0" cellpadding="0" cellspacing="0" style="width:600px;max-width:600px;background:#212529;">

    <!-- logo + slogan -->
    <tr><td align="center" style="padding:40px 56px 0;">
      <img src="{{ logo_url }}" width="96" alt="TRIIIPLE" style="display:block;width:96px;height:auto;border:0;">
      <div style="font-family:{{ fm }};font-size:9px;letter-spacing:3px;text-transform:uppercase;color:#6c7178;padding-top:12px;">wear it, own it, explain nothing</div>
    </td></tr>

    <!-- hero -->
    <tr><td style="padding:30px 0 0;">
      <img src="{{ banner_url }}" width="600" alt="TRIIIPLE" style="display:block;width:100%;max-width:600px;height:auto;border:0;">
    </td></tr>

    <!-- body -->
    <tr><td align="center" style="padding:38px 56px 0;">
      <div style="font-family:{{ fm }};font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#6c7178;padding-bottom:18px;">you're on the list</div>
      <div style="font-family:{{ fd }};font-size:46px;line-height:1.0;letter-spacing:-2px;color:#ffffff;">welcome<br>to the quiet.</div>
      <div style="font-family:{{ ff }};font-size:15px;line-height:1.75;color:#9aa0a6;padding:24px 0 0;">You signed up — which means you're early, and we like that. Basics built for Singapore humidity, made to disappear under everything. Two things to start you off:</div>
    </td></tr>

    <!-- code 1 -->
    <tr><td style="padding:30px 56px 0;">
      <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="border:1px dashed #4a4f55;">
        <tr><td align="center" style="padding:22px 20px;">
          <div style="font-family:{{ fm }};font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#9aa0a6;">10% off your first order</div>
          <div style="font-family:{{ fm }};font-size:26px;letter-spacing:3px;color:#ffffff;font-weight:bold;padding:10px 0 8px;">TRIIIPLE10</div>
          <div style="font-family:{{ fm }};font-size:9px;letter-spacing:1px;text-transform:uppercase;color:#6c7178;">minimum spend $35 · one use per customer</div>
        </td></tr>
      </table>
    </td></tr>

    <!-- code 2 -->
    <tr><td style="padding:14px 56px 0;">
      <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="border:1px dashed #4a4f55;">
        <tr><td align="center" style="padding:22px 20px;">
          <div style="font-family:{{ fm }};font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#9aa0a6;">buy 3, your 4th is free</div>
          <div style="font-family:{{ fm }};font-size:26px;letter-spacing:3px;color:#ffffff;font-weight:bold;padding:10px 0 8px;">FREESOCKS</div>
          <div style="font-family:{{ fm }};font-size:9px;letter-spacing:1px;text-transform:uppercase;color:#6c7178;">subscribers only · one use per customer</div>
        </td></tr>
      </table>
    </td></tr>

    <!-- CTA -->
    <tr><td align="center" style="padding:30px 56px 0;">
      <table role="presentation" border="0" cellpadding="0" cellspacing="0" align="center">
        <tr><td align="center" bgcolor="#ffffff" style="background:#ffffff;">
          <a href="{{ shop.url }}" style="display:inline-block;padding:17px 40px;font-family:{{ fm }};font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#212529;text-decoration:none;">shop the studio</a>
        </td></tr>
      </table>
      <div style="font-family:{{ fm }};font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:#6c7178;padding-top:18px;">codes apply at checkout. no rush — but socks don't last forever.</div>
    </td></tr>

    <!-- footer -->
    <tr><td style="padding:46px 0 0;">
      <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="background:#2a2e33;">
        <tr><td align="center" style="padding:36px 56px 40px;">
          <div style="font-family:{{ ff }};font-size:13px;line-height:1.65;color:#9aa0a6;max-width:300px;margin:0 auto;">That's it from us for now. We keep the inbox quiet — only the drops worth knowing about.</div>
          <div style="width:28px;height:1px;background:#383c41;margin:24px auto;font-size:0;line-height:0;">&nbsp;</div>
          <table role="presentation" border="0" cellpadding="0" cellspacing="0" align="center"><tr>
            <td style="padding:0 5px;"><a href="https://www.facebook.com/triiiplestudio"><img src="{{ ic_facebook }}" width="18" height="18" alt="Facebook" style="display:block;border:1px solid #383c41;padding:11px;background:#2a2e33;"></a></td>
            <td style="padding:0 5px;"><a href="https://www.instagram.com/triiiple_studio"><img src="{{ ic_instagram }}" width="18" height="18" alt="Instagram" style="display:block;border:1px solid #383c41;padding:11px;background:#2a2e33;"></a></td>
            <td style="padding:0 5px;"><a href="https://www.pinterest.com/triiiple_studio/"><img src="{{ ic_pinterest }}" width="18" height="18" alt="Pinterest" style="display:block;border:1px solid #383c41;padding:11px;background:#2a2e33;"></a></td>
          </tr></table>
          <img src="{{ logo_url }}" width="78" alt="TRIIIPLE" style="display:block;width:78px;height:auto;border:0;margin:28px auto 14px;opacity:0.7;">
          <div style="font-family:{{ fm }};font-size:9px;letter-spacing:1px;color:#6c7178;line-height:2;">© 2026 triiiple studio · singapore · sgd<br>no longer want these? {{ unsubscribe_link }}</div>
        </td></tr>
      </table>
    </td></tr>

  </table>

</td></tr>
</table>
