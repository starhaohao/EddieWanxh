{%- comment -%}
══════════════════════════════════════════════════════════════════
  TRIIIPLE · EMAIL 02 — WELCOME BACK (second order)
  Trigger: Order created → branch where order count = 2
  Type: Shopify transactional email
  Paste into: Settings → Notifications → "Order confirmation" → Edit code
──────────────────────────────────────────────────────────────────
  ARCHITECTURE: Shopify owns consent & sends this email.
  Klaviyo syncs the subscriber list only — no Klaviyo code here.

  Upload in Settings → Files and paste each URL below:
    triiiple-logo-white.png + the 3 product shots + 3 social icons.
  Swap the product handles in p1_url / p2_url / p3_url for real ones.
══════════════════════════════════════════════════════════════════
{%- endcomment -%}

{%- assign logo_url     = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/TRIIIPLE_LOGO_White.png?v=1760773519" -%}
{%- assign ic_facebook  = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/File_1.png?v=1780662733" -%}
{%- assign ic_instagram = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/File_4.png?v=1780662734" -%}
{%- assign ic_pinterest = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/File_7.png?v=1780662734" -%}

{%- assign p1_img = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/Y-Transdry-brief.jpg?v=1780135298" -%}{%- assign p1_url = "/products/y-transdry-brief-white" -%}
{%- assign p2_img = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/TSU1001-Blk-Front.jpg?v=1773822760" -%}{%- assign p2_url = "/products/v-cotton-spandex-brief-black" -%}
{%- assign p3_img = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/V_Brief.jpg?v=1780134537" -%}{%- assign p3_url = "/products/v-cotton-spandex-brief-white" -%}

{%- assign ff = "'Helvetica Neue', Helvetica, Arial, sans-serif" -%}
{%- assign fm = "'Courier New', Courier, monospace" -%}
{%- assign fd = "Galdeano, 'Helvetica Neue', Helvetica, Arial, sans-serif" -%}

<div style="display:none;max-height:0;overflow:hidden;opacity:0;mso-hide:all;">Twice now. That's not nothing — thank you.&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;</div>

<table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="background:#15171a;">
<tr><td align="center" style="padding:24px 12px;">

  <table role="presentation" width="600" border="0" cellpadding="0" cellspacing="0" style="width:600px;max-width:600px;background:#212529;">

    <!-- body -->
    <tr><td align="center" style="padding:48px 56px 0;">
      <div style="font-family:{{ fm }};font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#6c7178;padding-bottom:18px;">order {{ order.name }} · repeat customer</div>
      <div style="font-family:{{ fd }};font-size:44px;line-height:1.0;letter-spacing:-2px;color:#ffffff;">good to<br>see you again.</div>
      <div style="font-family:{{ ff }};font-size:15px;line-height:1.75;color:#9aa0a6;padding:24px 0 0;">Most people buy basics once and forget they own them. You came back — which tells us the first set earned its place in the drawer.</div>
      <div style="font-family:{{ ff }};font-size:15px;line-height:1.75;color:#9aa0a6;padding:16px 0 0;">That's the whole point of what we make: quiet things you reach for without thinking. Thank you for keeping us in the rotation.</div>
