{%- comment -%}
══════════════════════════════════════════════════════════════════
  TRIIIPLE · EMAIL 08 — CUSTOMER ACCOUNT INVITE
  Settings → Notifications → "Customer account invite" → Edit code
  This is a NOTIFICATION template — paste as the FULL email code.
──────────────────────────────────────────────────────────────────
  ARCHITECTURE: Shopify sends this email. Klaviyo syncs data only.
  Keep the CTA link variable intact — Shopify needs it.
  Logo wired to CDN; the 3 social icon URLs are placeholders.
══════════════════════════════════════════════════════════════════
{%- endcomment -%}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>You're invited to create an account</title>
</head>
<body style="margin:0;padding:0;background:#15171a;">

{%- assign logo_url     = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/TRIIIPLE_LOGO_White.png?v=1760773519" -%}
{%- assign ic_facebook  = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/File_1.png?v=1780662733" -%}
{%- assign ic_instagram = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/File_4.png?v=1780662734" -%}
{%- assign ic_pinterest = "https://cdn.shopify.com/s/files/1/0738/4947/0999/files/File_7.png?v=1780662734" -%}

{%- assign ff = "'Helvetica Neue', Helvetica, Arial, sans-serif" -%}
{%- assign fm = "'Courier New', Courier, monospace" -%}
{%- assign fd = "Galdeano, 'Helvetica Neue', Helvetica, Arial, sans-serif" -%}

<div style="display:none;max-height:0;overflow:hidden;opacity:0;mso-hide:all;">One tap to set up your TRIIIPLE account.&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;</div>

<table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="background:#15171a;">
<tr><td align="center" style="padding:24px 12px;">

  <table role="presentation" width="600" border="0" cellpadding="0" cellspacing="0" style="width:600px;max-width:600px;background:#212529;">

    <tr><td align="center" style="padding:48px 56px 0;">
      <img src="{{ logo_url }}" width="104" alt="TRIIIPLE" style="display:block;width:104px;height:auto;border:0;">
      <div style="font-family:{{ fm }};font-size:9px;letter-spacing:3px;text-transform:uppercase;color:#6c7178;padding-top:14px;">wear it, own it, explain nothing</div>
    </td></tr>

    <tr><td align="center" style="padding:52px 56px 0;">
      <div style="font-family:{{ fm }};font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#6c7178;padding-bottom:18px;">you're invited</div>
      <div style="font-family:{{ fd }};font-size:46px;line-height:1.0;letter-spacing:-2px;color:#ffffff;">create<br>your account.</div>
      <div style="font-family:{{ ff }};font-size:15px;line-height:1.75;color:#9aa0a6;padding:24px 0 0;">You've been invited to create a TRIIIPLE account — faster checkout, order history, the works. One tap sets it up.</div>
      {%- if custom_message != blank -%}
      <div style="font-family:{{ ff }};font-size:15px;line-height:1.75;color:#9aa0a6;padding:14px 0 0;">{{ custom_message }}</div>
      {%- else -%}
      <div style="font-family:{{ ff }};font-size:14px;line-height:1.7;color:#6c7178;padding:14px 0 0;">Didn't expect this? You can ignore it — no account gets created.</div>
      {%- endif -%}
    </td></tr>

    <tr><td align="center" style="padding:36px 56px 4px;">
      <table role="presentation" border="0" cellpadding="0" cellspacing="0" align="center">
        <tr><td align="center" bgcolor="#ffffff" style="background:#ffffff;">
          <a href="{{ customer.account_activation_url }}" style="display:inline-block;padding:18px 44px;font-family:{{ fm }};font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#212529;text-decoration:none;">activate account</a>
        </td></tr>
      </table>
    </td></tr>

    <tr><td style="padding:52px 0 0;">
      <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="background:#2a2e33;">
        <tr><td align="center" style="padding:36px 56px 40px;">
          <div style="font-family:{{ ff }};font-size:13px;line-height:1.65;color:#9aa0a6;max-width:340px;margin:0 auto;">Questions? Reach us at <a href="mailto:info@triiiplestudio.com" style="color:#ececed;text-decoration:underline;">info@triiiplestudio.com</a>.</div>
          <div style="width:28px;height:1px;background:#383c41;margin:24px auto;font-size:0;line-height:0;">&nbsp;</div>
          <table role="presentation" border="0" cellpadding="0" cellspacing="0" align="center"><tr>
            <td style="padding:0 5px;"><a href="https://www.facebook.com/triiiplestudio"><img src="{{ ic_facebook }}" width="18" height="18" alt="Facebook" style="display:block;border:1px solid #383c41;padding:11px;background:#2a2e33;"></a></td>
            <td style="padding:0 5px;"><a href="https://www.instagram.com/triiiple_studio"><img src="{{ ic_instagram }}" width="18" height="18" alt="Instagram" style="display:block;border:1px solid #383c41;padding:11px;background:#2a2e33;"></a></td>
            <td style="padding:0 5px;"><a href="https://www.pinterest.com/triiiple_studio/"><img src="{{ ic_pinterest }}" width="18" height="18" alt="Pinterest" style="display:block;border:1px solid #383c41;padding:11px;background:#2a2e33;"></a></td>
          </tr></table>
          <img src="{{ logo_url }}" width="78" alt="TRIIIPLE" style="display:block;width:78px;height:auto;border:0;margin:28px auto 14px;opacity:0.7;">
          <div style="font-family:{{ fm }};font-size:9px;letter-spacing:1px;color:#6c7178;line-height:2;">© 2026 triiiple studio · singapore · sgd</div>
        </td></tr>
      </table>
    </td></tr>

  </table>

</td></tr>
</table>
</body>
</html>
